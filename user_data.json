{"code":"<!DOCTYPE html>\n<html lang=\"bn\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\n    <title>আল্ট্রা স্মার্ট মিডিয়া ও প্রোফাইল গ্যালারি<\/title>\n    <link rel=\"stylesheet\" href=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/font-awesome\/6.4.0\/css\/all.min.css\">\n    <style>\n        @import url('https:\/\/fonts.googleapis.com\/css2?family=Hind+Siliguri:wght@400;600;700&family=Poppins:wght@400;600;700&display=swap');\n\n        \/* গ্লোবাল এবং ডাইনামিক থিম ভ্যারিয়েবল ইঞ্জিন *\/\n        :root {\n            \/* ডিফল্ট (ফটো গ্যালারি) থিম *\/\n            --bg-color: #060913;\n            --text-main: #f1f5f9;\n            --text-muted: #94a3b8;\n            --dashboard-bg: rgba(15, 23, 42, 0.6);\n            --card-bg: #111726;\n            --border-color: rgba(56, 189, 248, 0.2);\n            --search-bg: rgba(15, 23, 42, 0.9);\n            --accent-1: #38bdf8;\n            --accent-2: #6366f1;\n        }\n\n        body.theme-photo {\n            --bg-color: #060913;\n            --text-main: #f1f5f9;\n            --text-muted: #94a3b8;\n            --dashboard-bg: rgba(15, 23, 42, 0.6);\n            --card-bg: #111726;\n            --border-color: rgba(56, 189, 248, 0.2);\n            --search-bg: rgba(15, 23, 42, 0.9);\n            --accent-1: #38bdf8;\n            --accent-2: #6366f1;\n        }\n\n        body.theme-profile {\n            \/* প্রিমিয়াম সবুজ থিম (আপনার রিকুয়েস্ট অনুযায়ী) *\/\n            --bg-color: #021c13;\n            --text-main: #ecfdf5;\n            --text-muted: #a7f3d0;\n            --dashboard-bg: rgba(6, 78, 59, 0.6);\n            --card-bg: #064e3b;\n            --border-color: rgba(16, 185, 129, 0.3);\n            --search-bg: rgba(2, 44, 34, 0.9);\n            --accent-1: #10b981;\n            --accent-2: #059669;\n        }\n\n        body.theme-video {\n            \/* ক্লিন লাইট থিম *\/\n            --bg-color: #f8fafc;\n            --text-main: #0f172a;\n            --text-muted: #64748b;\n            --dashboard-bg: #ffffff;\n            --card-bg: #ffffff;\n            --border-color: #cbd5e1;\n            --search-bg: #ffffff;\n            --accent-1: #6366f1;\n            --accent-2: #8b5cf6;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Hind Siliguri', 'Poppins', sans-serif;\n            transition: background 0.4s ease, color 0.4s ease, border-color 0.4s ease;\n        }\n\n        body {\n            background: var(--bg-color);\n            color: var(--text-main);\n            min-height: 100vh;\n            padding: 20px 15px;\n            overflow-x: hidden;\n        }\n\n        \/* প্রফেশনাল ড্যাশবোর্ড *\/\n        .stats-dashboard {\n            max-width: 1200px;\n            margin: 0 auto 25px;\n            background: var(--dashboard-bg);\n            border: 1px solid var(--border-color);\n            backdrop-filter: blur(12px);\n            border-radius: 20px;\n            padding: 20px;\n            display: flex;\n            justify-content: space-around;\n            align-items: center;\n            flex-wrap: wrap;\n            gap: 15px;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.08);\n        }\n\n        .stat-item {\n            text-align: center;\n            flex: 1;\n            min-width: 120px;\n        }\n\n        .stat-item p {\n            font-size: 0.9rem;\n            color: var(--text-muted);\n            margin-bottom: 6px;\n            font-weight: 600;\n        }\n\n        .stat-item span {\n            font-size: 1.8rem;\n            font-weight: 700;\n            color: var(--accent-1);\n        }\n\n        header h1 {\n            text-align: center;\n            font-size: 2.2rem;\n            font-weight: 700;\n            margin-bottom: 25px;\n            background: linear-gradient(to right, var(--accent-1), var(--accent-2));\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n        }\n\n        \/* মডার্ন ট্যাব সুইচ বোতাম *\/\n        .media-type-switcher {\n            display: flex;\n            justify-content: center;\n            gap: 12px;\n            margin-bottom: 25px;\n            flex-wrap: wrap;\n        }\n\n        .type-btn {\n            padding: 12px 22px;\n            font-size: 0.95rem;\n            font-weight: 600;\n            border: none;\n            border-radius: 30px;\n            background: var(--card-bg);\n            color: var(--text-main);\n            border: 1px solid var(--border-color);\n            cursor: pointer;\n            box-shadow: 0 4px 10px rgba(0,0,0,0.05);\n            display: flex;\n            align-items: center;\n            gap: 8px;\n            transition: all 0.3s ease;\n        }\n\n        .type-btn:hover {\n            transform: translateY(-2px);\n        }\n\n        .type-btn.active {\n            background: linear-gradient(135deg, var(--accent-1), var(--accent-2));\n            color: #fff;\n            box-shadow: 0 5px 20px rgba(0,0,0,0.2);\n            border-color: transparent;\n        }\n\n        \/* অ্যাডভান্সড সার্চ ফিল্ড *\/\n        .search-container {\n            max-width: 550px;\n            margin: 0 auto 30px;\n            position: relative;\n        }\n\n        .search-container input {\n            width: 100%;\n            padding: 15px 20px 15px 55px;\n            border: none;\n            border-radius: 30px;\n            background: var(--search-bg);\n            color: var(--text-main);\n            font-size: 1rem;\n            border: 1px solid var(--border-color);\n            box-shadow: 0 4px 15px rgba(0,0,0,0.05);\n        }\n\n        .search-container input::placeholder {\n            color: var(--text-muted);\n        }\n\n        .search-container input:focus {\n            outline: none;\n            border-color: var(--accent-1);\n            box-shadow: 0 0 20px rgba(0,0,0,0.1);\n        }\n\n        .search-container i {\n            position: absolute;\n            left: 22px;\n            top: 50%;\n            transform: translateY(-50%);\n            color: var(--accent-1);\n            font-size: 1.1rem;\n        }\n\n        \/* প্রিমিয়াম গ্রিড লেআউট *\/\n        .gallery-container {\n            display: grid;\n            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));\n            gap: 20px;\n            max-width: 1300px;\n            margin: 0 auto;\n            padding: 5px;\n        }\n\n        @media (max-width: 480px) {\n            .gallery-container {\n                grid-template-columns: repeat(2, 1fr);\n                gap: 12px;\n            }\n        }\n\n        .gallery-item {\n            position: relative;\n            border-radius: 18px;\n            overflow: hidden;\n            cursor: pointer;\n            aspect-ratio: 1 \/ 1;\n            background: var(--card-bg);\n            border: 1px solid var(--border-color);\n            box-shadow: 0 4px 15px rgba(0,0,0,0.1);\n            transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s;\n        }\n\n        .gallery-item:hover {\n            transform: translateY(-8px) scale(1.02);\n            box-shadow: 0 15px 30px rgba(0,0,0,0.2);\n            border-color: var(--accent-1);\n        }\n\n        .gallery-item img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            display: block;\n            transition: opacity 0.3s;\n        }\n\n        \/* ভিডিও প্লে বাটন ওভারলে *\/\n        .play-overlay {\n            position: absolute;\n            inset: 0;\n            background: rgba(0, 0, 0, 0.3);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            transition: background 0.3s;\n        }\n\n        .gallery-item:hover .play-overlay {\n            background: rgba(0, 0, 0, 0.5);\n        }\n\n        .play-icon {\n            width: 55px;\n            height: 55px;\n            background: rgba(255, 255, 255, 0.25);\n            backdrop-filter: blur(8px);\n            border-radius: 50%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            border: 2px solid #fff;\n            box-shadow: 0 4px 15px rgba(0,0,0,0.2);\n        }\n\n        .play-icon i {\n            color: #fff;\n            font-size: 1.3rem;\n            margin-left: 4px;\n        }\n\n        \/* মডার্ন লাইটবক্স মোডাল *\/\n        .modal {\n            position: fixed;\n            inset: 0;\n            background: rgba(4, 6, 12, 0.95);\n            backdrop-filter: blur(20px);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            flex-direction: column;\n            opacity: 0;\n            pointer-events: none;\n            z-index: 9999;\n            transition: opacity 0.3s ease;\n            padding: 20px;\n        }\n\n        .modal.active {\n            opacity: 1;\n            pointer-events: auto;\n        }\n\n        .modal-body {\n            max-width: 90vw;\n            max-height: 75vh;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            transform: scale(0.9);\n            transition: transform 0.3s ease;\n        }\n\n        .modal.active .modal-body {\n            transform: scale(1);\n        }\n\n        .modal img, .modal video {\n            max-width: 100%;\n            max-height: 75vh;\n            object-fit: contain;\n            border-radius: 16px;\n            box-shadow: 0 20px 50px rgba(0,0,0,0.6);\n        }\n\n        .close-btn {\n            position: absolute;\n            top: 25px;\n            right: 30px;\n            font-size: 2.5rem;\n            color: #e2e8f0;\n            cursor: pointer;\n            transition: transform 0.2s, color 0.2s;\n            z-index: 10000;\n        }\n\n        .close-btn:hover { color: #f43f5e; transform: scale(1.1); }\n\n        .download-btn {\n            margin-top: 25px;\n            padding: 14px 40px;\n            font-size: 1rem;\n            font-weight: 600;\n            color: #fff;\n            background: linear-gradient(135deg, var(--accent-1), var(--accent-2));\n            border: none;\n            border-radius: 30px;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            gap: 10px;\n            box-shadow: 0 10px 25px rgba(0,0,0,0.3);\n            transition: transform 0.2s;\n        }\n        \n        .download-btn:active {\n            transform: scale(0.95);\n        }\n    <\/style>\n<\/head>\n<body class=\"theme-photo\"> \n\n    <div class=\"stats-dashboard\">\n        <div class=\"stat-item\">\n            <p><i class=\"fa-solid fa-database\"><\/i> মোট কালেকশন<\/p>\n            <span id=\"totalMedia\">0<\/span>\n        <\/div>\n        <div class=\"stat-item\">\n            <p><i class=\"fa-solid fa-bolt\"><\/i> আনলকড রিলিজ<\/p>\n            <span id=\"dailyNew\">0<\/span>\n        <\/div>\n        <div class=\"stat-item\">\n            <p><i class=\"fa-solid fa-eye\"><\/i> বর্তমান ভিউ<\/p>\n            <span id=\"currentView\">0<\/span>\n        <\/div>\n    <\/div>\n\n    <header>\n        <h1>আল্ট্রা স্মার্ট মিডিয়া প্রো<\/h1>\n    <\/header>\n\n    <div class=\"media-type-switcher\">\n        <button class=\"type-btn active\" id=\"btn-photo\" onclick=\"changeTab('photo')\"><i class=\"fa-solid fa-image\"><\/i> ফটো গ্যালারি<\/button>\n        <button class=\"type-btn\" id=\"btn-profile\" onclick=\"changeTab('profile')\"><i class=\"fa-solid fa-user-circle\"><\/i> প্রোফাইল পিকচার<\/button>\n        <button class=\"type-btn\" id=\"btn-video\" onclick=\"changeTab('video')\"><i class=\"fa-solid fa-circle-play\"><\/i> ভিডিও কালেকশন<\/button>\n    <\/div>\n\n    <div class=\"search-container\">\n        <i class=\"fa-solid fa-magnifying-glass\"><\/i>\n        <input type=\"text\" id=\"searchInput\" placeholder=\"খুঁজুন (যেমন: গাড়ি, car, nature, gaming, ছেলে, মেয়ে)...\">\n    <\/div>\n\n    <main class=\"gallery-container\" id=\"galleryGrid\"><\/main>\n\n    <div class=\"modal\" id=\"mediaModal\">\n        <span class=\"close-btn\" onclick=\"closeModal()\"><i class=\"fa-solid fa-xmark\"><\/i><\/span>\n        <div class=\"modal-body\" id=\"modalContent\"><\/div>\n        <button class=\"download-btn\" id=\"downloadBtn\"><i class=\"fa-solid fa-download\"><\/i> গ্যালারিতে সেভ করুন<\/button>\n    <\/div>\n\n    <script>\n        let currentTab = 'photo';\n        let fullDatabase = [];\n        let currentlyUnlockedData = [];\n\n        \/\/ ১. প্রফেশনাল পোলিনেশন এআই ডেটাবেস ইঞ্জিন (১০০% র্কিং)\n        function generateSmartDatabase() {\n            fullDatabase = []; \n            \n            \/\/ ফটো গ্যালারি ডেটা\n            const photoCollections = [\n                { type: 'photo', tags: ['গাড়ি', 'car', 'supercar', 'গাড়ি'], terms: ['ferrari-car', 'lamborghini-aventador', 'porsche-911', 'audi-r8', 'mclaren', 'toyota-supra'] },\n                { type: 'photo', tags: ['প্রকৃতি', 'nature', 'landscape', 'পাহাড়'], terms: ['beautiful-mountain', 'dense-forest', 'waterfall-nature', 'river-sunset', 'snow-peaks'] },\n                { type: 'photo', tags: ['শহর', 'city', 'urban', 'cyberpunk'], terms: ['tokyo-night-street', 'new-york-city', 'cyberpunk-neon-city', 'dubai-cityscape'] }\n            ];\n\n            \/\/ প্রোফাইল কালেকশন (ছেলে, মেয়ে ও গেমিং)\n            const profileCollections = [\n                { type: 'profile', tags: ['গেমিং', 'gaming', 'avatar', 'গেমিং প্রোফাইল'], terms: ['esports-gaming-avatar', 'cyberpunk-gamer-boy', 'anime-gamer-girl', 'neon-mask-avatar'] },\n                { type: 'profile', tags: ['ছেলে', 'boy', 'man', 'স্মার্ট ছেলে'], terms: ['handsome-smart-boy', 'cool-guy-portrait', 'stylish-man-photography', 'aesthetic-boy'] },\n                { type: 'profile', tags: ['মেয়ে', 'girl', 'woman', 'সুন্দর মেয়ে'], terms: ['beautiful-cute-girl', 'aesthetic-girl-portrait', 'fashion-model-woman', 'hijabi-girl-portrait'] }\n            ];\n\n            let globalId = 1;\n\n            \/\/ এআই ইমেজ জেনারেটর মেকানিজম (Unsplash-এর বিকল্প, অনেক ফাস্ট ও নির্ভরযোগ্য)\n            const generateImageURL = (term, id) => `https:\/\/image.pollinations.ai\/prompt\/${term}?width=500&height=500&nologo=true&seed=${id}`;\n\n            photoCollections.forEach(group => {\n                group.terms.forEach((term) => {\n                    fullDatabase.push({\n                        id: globalId++,\n                        type: group.type,\n                        searchTags: group.tags,\n                        url: generateImageURL(term, globalId)\n                    });\n                });\n            });\n\n            profileCollections.forEach(group => {\n                group.terms.forEach((term) => {\n                    fullDatabase.push({\n                        id: globalId++,\n                        type: group.type,\n                        searchTags: group.tags,\n                        url: generateImageURL(term, globalId)\n                    });\n                });\n            });\n\n            \/\/ ২. ডাইনামিক রিয়েল ভিডিও স্ট্রিম ডেটাবেস (ফাস্ট সিডিএন)\n            const premiumVideos = [\n                { id: 9001, type: 'video', searchTags: ['গাড়ি', 'car', 'racing'], thumb: generateImageURL('sports-car-racing', 9001), url: 'https:\/\/commondatastorage.googleapis.com\/gtv-videos-bucket\/sample\/ForBiggerBlazes.mp4' },\n                { id: 9002, type: 'video', searchTags: ['প্রকৃতি', 'nature', 'video'], thumb: generateImageURL('beautiful-nature-waterfall', 9002), url: 'https:\/\/commondatastorage.googleapis.com\/gtv-videos-bucket\/sample\/ElephantsDream.mp4' },\n                { id: 9003, type: 'video', searchTags: ['শহর', 'city', 'tech'], thumb: generateImageURL('cyberpunk-city-night', 9003), url: 'https:\/\/commondatastorage.googleapis.com\/gtv-videos-bucket\/sample\/TearsOfSteel.mp4' },\n                { id: 9004, type: 'video', searchTags: ['গেমিং', 'gaming', 'animation'], thumb: generateImageURL('esports-gaming-setup', 9004), url: 'https:\/\/commondatastorage.googleapis.com\/gtv-videos-bucket\/sample\/BigBuckBunny.mp4' }\n            ];\n            \n            fullDatabase = [...fullDatabase, ...premiumVideos];\n        }\n\n        \/\/ ৩. ডাইনামিক ডেটা লোডার\n        function loadSystemData() {\n            \/\/ ইউজারের সুবিধার জন্য এখন সব মিডিয়া একসাথে আনলক থাকবে\n            currentlyUnlockedData = fullDatabase;\n            \n            document.getElementById('totalMedia').innerText = fullDatabase.length + \" টি\";\n            document.getElementById('dailyNew').innerText = \"100%\";\n        }\n\n        \/\/ ৪. প্রফেশনাল গ্রিড রেন্ডারিং সিস্টেম\n        function renderGrid(searchFilter = '') {\n            const grid = document.getElementById('galleryGrid');\n            grid.innerHTML = '';\n            const query = searchFilter.trim().toLowerCase();\n\n            const finalFiltered = currentlyUnlockedData.filter(item => {\n                const isCorrectTab = item.type === currentTab;\n                const isCorrectSearch = query === '' || item.searchTags.some(tag => tag.toLowerCase().includes(query));\n                return isCorrectTab && isCorrectSearch;\n            });\n\n            if(finalFiltered.length === 0) {\n                grid.innerHTML = `<p style=\"grid-column: 1\/-1; text-align:center; color: var(--text-muted); padding:50px; font-size:1.1rem;\">কোনো ডাটা পাওয়া যায়নি। সঠিক কি-ওয়ার্ড লিখুন (যেমন: car, boy, girl, nature)।<\/p>`;\n                document.getElementById('currentView').innerText = \"0 টি\";\n                return;\n            }\n\n            finalFiltered.forEach(item => {\n                const card = document.createElement('div');\n                card.className = 'gallery-item';\n\n                if (item.type === 'video') {\n                    card.innerHTML = `\n                        <img src=\"${item.thumb}\" alt=\"Video Thumbnail\" loading=\"lazy\">\n                        <div class=\"play-overlay\"><div class=\"play-icon\"><i class=\"fa-solid fa-play\"><\/i><\/div><\/div>\n                    `;\n                    card.onclick = () => openVideo(item.url);\n                } else {\n                    card.innerHTML = `<img src=\"${item.url}\" alt=\"Premium Media\" loading=\"lazy\">`;\n                    card.onclick = () => openPhoto(item.url);\n                }\n                grid.appendChild(card);\n            });\n\n            document.getElementById('currentView').innerText = finalFiltered.length + \" টি\";\n        }\n\n        \/\/ ৫. থিম এবং ট্যাব কন্ট্রোলার মেথড\n        function changeTab(tabName) {\n            currentTab = tabName;\n            \n            \/\/ বডিতে নতুন থিম ক্লাস অ্যাড করা\n            document.body.className = 'theme-' + tabName;\n\n            \/\/ বাটন অ্যাক্টিভ স্টেট চেঞ্জ করা\n            document.querySelectorAll('.type-btn').forEach(btn => btn.classList.remove('active'));\n            document.getElementById(`btn-${tabName}`).classList.add('active');\n\n            document.getElementById('searchInput').value = ''; \n            renderGrid();\n        }\n\n        \/\/ লাইভ রিয়েলটাইম সার্চ ইঞ্জিন লিসেনার\n        document.getElementById('searchInput').addEventListener('input', (e) => {\n            renderGrid(e.target.value);\n        });\n\n        \/\/ ৬. ফুল স্ক্রিন লাইটবক্স মোডাল হ্যান্ডলার\n        function openPhoto(url) {\n            document.getElementById('modalContent').innerHTML = `<img id=\"activeMedia\" src=\"${url}\">`;\n            document.getElementById('mediaModal').classList.add('active');\n            document.getElementById('downloadBtn').onclick = () => downloadMedia(url, 'Image.jpg');\n        }\n\n        function openVideo(url) {\n            document.getElementById('modalContent').innerHTML = `\n                <video id=\"activeMedia\" controls autoplay loop style=\"width:100%; max-height: 75vh;\">\n                    <source src=\"${url}\" type=\"video\/mp4\">\n                <\/video>`;\n            document.getElementById('mediaModal').classList.add('active');\n            document.getElementById('downloadBtn').onclick = () => downloadMedia(url, 'Video.mp4');\n        }\n\n        function closeModal() {\n            const media = document.getElementById('activeMedia');\n            if (media && media.tagName === 'VIDEO') media.pause(); \n            document.getElementById('mediaModal').classList.remove('active');\n        }\n\n        \/\/ ৭. সুপার-ফাস্ট ডাউনলোডার ইঞ্জিন\n        async function downloadMedia(url, filename) {\n            const btn = document.getElementById('downloadBtn');\n            const originalContent = btn.innerHTML;\n            \n            try {\n                btn.innerHTML = `<i class=\"fa-solid fa-spinner fa-spin\"><\/i> প্রসেসিং...`;\n                const res = await fetch(url);\n                const blob = await res.blob();\n                const blobUrl = URL.createObjectURL(blob);\n                \n                const a = document.createElement('a');\n                a.href = blobUrl;\n                a.download = `MediaPro_${Date.now()}_${filename}`;\n                document.body.appendChild(a);\n                a.click();\n                document.body.removeChild(a);\n                \n                btn.innerHTML = `<i class=\"fa-solid fa-circle-check\"><\/i> কমপ্লিট!`;\n                setTimeout(() => btn.innerHTML = originalContent, 2000);\n            } catch {\n                \/\/ ব্রাউজার সিকিউরিটি (CORS) ব্লক করলে অল্টারনেটিভ সিস্টেম\n                const a = document.createElement('a');\n                a.href = url;\n                a.target = \"_blank\";\n                a.download = `MediaPro_${Date.now()}_${filename}`;\n                document.body.appendChild(a);\n                a.click();\n                document.body.removeChild(a);\n                \n                btn.innerHTML = `<i class=\"fa-solid fa-circle-check\"><\/i> ওপেন হয়েছে, সেভ করুন!`;\n                setTimeout(() => btn.innerHTML = originalContent, 3000);\n            }\n        }\n\n        \/\/ অ্যাপ ইনিশিয়েশন এক্সিকিউশন\n        generateSmartDatabase();\n        loadSystemData();\n        renderGrid();\n    <\/script>\n<\/body>\n<\/html>\n","icon":"\/9j\/4AAQSkZJRgABAQAAAQABAAD\\/bAEMADQkKCwoIDQsKCw4ODQ8TIBUTEhITJxweFyAuKTEwLiktLDM6Sj4zNkY3LC1AV0FGTE5SU1IyPlphWlBgSlFST\/\/bAEMBDg4OExETJhUVJk81LTVPT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT\/\/AABEIAGAAYAMBIgACEQEDEQH\/xAAcAAACAgMBAQAAAAAAAAAAAAAABwQFAgMGAQj\/xABCEAABAwMBBAQKBggHAAAAAAABAgMEAAUREgYHEyExN4GxFCJBUWFxcnSRoRUXIzJVtCWSlKKywtHSM1NjgqSzwf\/EABQBAQAAAAAAAAAAAAAAAAAAAAD\/xAAUEQEAAAAAAAAAAAAAAAAAAAAA\/9oADAMBAAIRAxEAPwBYUUVJegTY7CX5EOQ0yvGlxbakpVkZGCR5qCNRUmNb50xBXEhyH0pOCpppSgD2Cs2LVcpDSXo9vlutq+6tDKlA+TkQKCHRU\/6Eu\/4VO\/Z1\/wBKjNxZDsnwZqO6t\/JHCSglWR08umg00VsfYejPFmQ0406npQ4kpUOw1segzGH0MPxH23nMaG1tkKVk4GAeZ50Eeip\/0Jd\/wqd+zr\/pWDNquUhoOx7fLdbVnC0MqUDjl0gUEOis3WnGXFNvNqbcScKSoYIPpFYUBTYuzrVy3LsPhrJYZZSnVzIUhYbJHYFdhpT01tiXHp+667QwOItpMhplAHPm3qA\/WUaDbu+W\/a93FxuAQNQU\/IZ1dCtKAP4kEV0ey02CzsLAmIWExY8MKdUEHkUD7Q4xk8wr11yk\/Nq3LR2HHtLslCOHpz43Ec4mn9TOe2p+zvU297lL73KC0+sHZT8V\/wCO7\/bUfawxUx7VtfDUkeButLW8E+M5GcISQARzOFcs4xk9BrkG9nbSd1JvRiD6Q0k8biK\/ztPRnHRy6Kvrv1LN+7R\/+xFBQ7xLciRvEhR0nSZyGQo+krKO4CrLbNCnd6uz6EAkgMKx6A8on5CvNtklW9TZ8AZ5Rz8HlVulSFSN90RpYGIzXDT6uCpfeo0HXXjamyWSWmLc5vAeUgOBPCWrxSSM5SD5QarthZTMXd\/Glvr0sNJfcWrBOEhxZJwOfRXHbxg8p+8uuZLQnQ2myfJhhxRH7+e2ug2e6mnvcpfe5QYbxottvWxyb\/EWhxTGhTTyBzWhSgkpPqJzg8wQRyyaUFNJHUYfZP5ilbQFMjc3KbTNukM54jrbbqfNhJIP8aaW9dvulDx2tXwigIEVfF1DmU6k9Hp1aezNBb70P0bsxYrKPHCMfadH+EgJ6PTr+VWmzvU297lL73KoN8Qk\/TNvUvV4MY5DfPlr1HV8tHyq\/wBnept73KX3uUEBnqNPsK\/MGp17Ycb3ONsrQQ54NGGnHPJcRyx56n7By48Hd5