{"code":"<!DOCTYPE html>\n<html lang=\"bn\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>প্রিমিয়াম মিডিয়া সেন্টার (ফটো ও ভিডিও গ্যালারি)<\/title>\n    <link rel=\"stylesheet\" href=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/font-awesome\/6.4.0\/css\/all.min.css\">\n    <style>\n        @import url('https:\/\/fonts.googleapis.com\/css2?family=Poppins:wght@300;400;600;700&display=swap');\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Poppins', sans-serif;\n        }\n\n        body {\n            background: #090d16;\n            color: #ffffff;\n            min-height: 100vh;\n            padding: 20px;\n            overflow-x: hidden;\n        }\n\n        \/* Header & Navigation *\/\n        header {\n            text-align: center;\n            margin-bottom: 30px;\n            margin-top: 20px;\n        }\n\n        header h1 {\n            font-size: 2.8rem;\n            font-weight: 700;\n            background: linear-gradient(to right, #38bdf8, #ec4899);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n            margin-bottom: 10px;\n        }\n\n        \/* Main Type Switcher (Photos vs Videos) *\/\n        .media-type-switcher {\n            display: flex;\n            justify-content: center;\n            gap: 20px;\n            margin-bottom: 30px;\n        }\n\n        .type-btn {\n            padding: 12px 35px;\n            font-size: 1.1rem;\n            font-weight: 600;\n            border: none;\n            border-radius: 30px;\n            background: rgba(255, 255, 255, 0.05);\n            color: #94a3b8;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n        }\n\n        .type-btn.active {\n            background: linear-gradient(135deg, #38bdf8, #c084fc);\n            color: #fff;\n            box-shadow: 0 0 20px rgba(56, 189, 248, 0.4);\n        }\n\n        \/* Search Controls *\/\n        .search-container {\n            max-width: 500px;\n            margin: 0 auto 25px;\n            position: relative;\n        }\n\n        .search-container input {\n            width: 100%;\n            padding: 15px 20px;\n            padding-left: 50px;\n            border: none;\n            border-radius: 30px;\n            background: rgba(255, 255, 255, 0.07);\n            color: #fff;\n            font-size: 1rem;\n            backdrop-filter: blur(10px);\n            transition: all 0.3s ease;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n        }\n\n        .search-container input:focus {\n            outline: none;\n            border-color: #38bdf8;\n            box-shadow: 0 0 15px rgba(56, 189, 248, 0.3);\n        }\n\n        .search-container i {\n            position: absolute;\n            left: 20px;\n            top: 50%;\n            transform: translateY(-50%);\n            color: #94a3b8;\n        }\n\n        \/* Media Grid System *\/\n        .gallery-container {\n            columns: 4 300px;\n            column-gap: 20px;\n            max-width: 1400px;\n            margin: 0 auto;\n        }\n\n        .gallery-item {\n            break-inside: avoid;\n            margin-bottom: 20px;\n            position: relative;\n            border-radius: 16px;\n            overflow: hidden;\n            cursor: pointer;\n            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n            box-shadow: 0 10px 20px rgba(0,0,0,0.4);\n            background: #1e293b;\n        }\n\n        .gallery-item:hover {\n            transform: scale(1.03);\n            box-shadow: 0 15px 30px rgba(56, 189, 248, 0.25);\n        }\n\n        .gallery-item img {\n            width: 100%;\n            display: block;\n            object-fit: cover;\n            border-radius: 16px;\n        }\n\n        \/* Video Play Icon Overlay (For home page thumbnails) *\/\n        .play-button-overlay {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 60px;\n            height: 60px;\n            background: rgba(255, 255, 255, 0.2);\n            backdrop-filter: blur(5px);\n            border-radius: 50%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            border: 2px solid #fff;\n            box-shadow: 0 0 20px rgba(0,0,0,0.3);\n            transition: all 0.3s ease;\n            z-index: 2;\n        }\n\n        .gallery-item:hover .play-button-overlay {\n            background: #fff;\n            transform: translate(-50%, -50%) scale(1.1);\n        }\n\n        .play-button-overlay i {\n            color: #fff;\n            font-size: 1.5rem;\n            margin-left: 4px; \/* Aligning triangle perfectly *\/\n            transition: color 0.3s ease;\n        }\n\n        .gallery-item:hover .play-button-overlay i {\n            color: #090d16;\n        }\n\n        \/* Lightbox Modal (For Full Screen) *\/\n        .modal {\n            position: fixed;\n            inset: 0;\n            background: rgba(5, 7, 12, 0.98);\n            backdrop-filter: blur(20px);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            flex-direction: column;\n            opacity: 0;\n            pointer-events: none;\n            z-index: 9999;\n            transition: opacity 0.4s ease;\n            padding: 20px;\n        }\n\n        .modal.active {\n            opacity: 1;\n            pointer-events: auto;\n        }\n\n        .modal-content-wrapper {\n            position: relative;\n            max-width: 85vw;\n            max-height: 70vh;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .modal img, .modal video {\n            max-width: 100%;\n            max-height: 70vh;\n            object-fit: contain;\n            border-radius: 12px;\n            box-shadow: 0 25px 50px rgba(0,0,0,0.7);\n            transform: scale(0.95);\n            transition: transform 0.4s ease;\n        }\n\n        .modal.active img, .modal.active video {\n            transform: scale(1);\n        }\n\n        .close-btn {\n            position: absolute;\n            top: 20px;\n            right: 30px;\n            font-size: 2.2rem;\n            color: #cbd5e1;\n            cursor: pointer;\n            transition: color 0.3s;\n        }\n\n        .close-btn:hover {\n            color: #ef4444;\n        }\n\n        \/* Action Buttons Below Media *\/\n        .modal-controls {\n            margin-top: 25px;\n            display: flex;\n            gap: 15px;\n        }\n\n        .btn {\n            padding: 14px 40px;\n            font-size: 1.1rem;\n            font-weight: 600;\n            color: #fff;\n            border: none;\n            border-radius: 30px;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            gap: 10px;\n            transition: all 0.3s ease;\n        }\n\n        .download-btn {\n            background: linear-gradient(135deg, #10b981, #059669);\n            box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3);\n        }\n\n        .download-btn:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 15px 25px rgba(16, 185, 129, 0.5);\n        }\n    <\/style>\n<\/head>\n<body>\n\n    <header>\n        <h1>প্রিমিয়াম মিডিয়া সেন্টার<\/h1>\n        <p style=\"color: #64748b;\">এইচডি ফটো এবং ভিডিও ডাউনলোডার অ্যাপ্লিকেশন<\/p>\n    <\/header>\n\n    <div class=\"media-type-switcher\">\n        <button class=\"type-btn active\" onclick=\"switchMediaType('photo')\"><i class=\"fa-solid fa-image\"><\/i> ফটো গ্যালারি<\/button>\n        <button class=\"type-btn\" onclick=\"switchMediaType('video')\"><i class=\"fa-solid fa-circle-play\"><\/i> ভিডিও কালেকশন<\/button>\n    <\/div>\n\n    <div class=\"search-container\">\n        <i class=\"fa-solid fa-magnifying-glass\"><\/i>\n        <input type=\"text\" id=\"searchInput\" placeholder=\"খুঁজুন (যেমন: nature, car, city)...\">\n    <\/div>\n\n    <main class=\"gallery-container\" id=\"galleryGrid\"><\/main>\n\n    <div class=\"modal\" id=\"mediaModal\">\n        <span class=\"close-btn\" onclick=\"closeModal()\"><i class=\"fa-solid fa-xmark\"><\/i><\/span>\n        <div class=\"modal-content-wrapper\" id=\"modalBody\">\n            <\/div>\n        <div class=\"modal-controls\">\n            <button class=\"btn download-btn\" id=\"downloadBtn\">\n                <i class=\"fa-solid fa-circle-down\"><\/i> গ্যালারিতে সেভ করুন\n            <\/button>\n        <\/div>\n    <\/div>\n\n    <script>\n        \/\/ ডাইনামিক ডেটাবেস (২০০+ ইমেজ এবং ১০+ স্যাম্পল ওপেন সোর্স অনলাইন ভিডিও)\n        let currentType = 'photo'; \n        let allPhotos = [];\n        let allVideos = [\n            { id: 1, title: 'nature forest waterfall', type: 'video', thumb: 'https:\/\/picsum.photos\/id\/10\/800\/600', url: 'https:\/\/vjs.zencdn.net\/v\/oceans.mp4' },\n            { id: 2, title: 'city traffic night light', type: 'video', thumb: 'https:\/\/picsum.photos\/id\/237\/800\/600', url: 'https:\/\/media.w3.org\/2010\/05\/sintel\/trailer_hd.mp4' },\n            { id: 3, title: 'nature river mountain green', type: 'video', thumb: 'https:\/\/picsum.photos\/id\/28\/800\/600', url: 'https:\/\/www.w3schools.com\/html\/mov_bbb.mp4' },\n            { id: 4, title: 'car highway speed drive', type: 'video', thumb: 'https:\/\/picsum.photos\/id\/54\/800\/600', url: 'https:\/\/media.w3.org\/2010\/05\/bunny\/movie.mp4' },\n            { id: 5, title: 'space galaxy stars sky', type: 'video', thumb: 'https:\/\/picsum.photos\/id\/96\/800\/600', url: 'https:\/\/vjs.zencdn.net\/v\/oceans.mp4' },\n            { id: 6, title: 'nature rain water drops', type: 'video', thumb: 'https:\/\/picsum.photos\/id\/48\/800\/600', url: 'https:\/\/www.w3schools.com\/html\/movie.mp4' }\n        ];\n\n        const galleryGrid = document.getElementById('galleryGrid');\n        const mediaModal = document.getElementById('mediaModal');\n        const modalBody = document.getElementById('modalBody');\n        const downloadBtn = document.getElementById('downloadBtn');\n        const searchInput = document.getElementById('searchInput');\n\n        \/\/ ২০০টি ডাইনামিক ফটো জেনারেট করার লুপ\n        function generatePhotos() {\n            const categories = ['nature', 'car', 'city', 'space', 'animals'];\n            for (let i = 1; i <= 200; i++) {\n                let cat = categories[i % categories.length];\n                allPhotos.push({\n                    id: i,\n                    title: `${cat} premium asset code ${i}`,\n                    type: 'photo',\n                    url: `https:\/\/picsum.photos\/id\/${(i + 15) % 500}\/800\/${600 + (i % 3) * 100}`\n                });\n            }\n            allPhotos.sort(() => Math.random() - 0.5);\n        }\n\n        \/\/ মেইন টাইপ চেঞ্জার (ফটো নাকি ভিডিও)\n        function switchMediaType(type) {\n            currentType = type;\n            document.querySelectorAll('.type-btn').forEach(btn => btn.classList.remove('active'));\n            if(type === 'photo') {\n                event.currentTarget.classList.add('active');\n                renderMedia(allPhotos);\n            } else {\n                event.currentTarget.classList.add('active');\n                renderMedia(allVideos);\n            }\n            searchInput.value = ''; \/\/ ক্লিয়ার সার্চ বার\n        }\n\n        \/\/ গ্রিডে আইটেম রেন্ডার করার মাস্টার ফাংশন\n        function renderMedia(mediaList) {\n            galleryGrid.innerHTML = '';\n            if(mediaList.length === 0) {\n                galleryGrid.innerHTML = `<p style=\"grid-column: 1\/-1; text-align:center; color:#64748b; padding: 40px;\">কোনো মিডিয়া ফাইল পাওয়া যায়নি!<\/p>`;\n                return;\n            }\n\n            mediaList.forEach(item => {\n                const card = document.createElement('div');\n                card.className = 'gallery-item';\n\n                if(item.type === 'photo') {\n                    card.innerHTML = `<img src=\"${item.url}\" alt=\"${item.title}\" loading=\"lazy\">`;\n                    card.onclick = () => openPhoto(item.url);\n                } else {\n                    \/\/ ভিডিওর জন্য থাম্বনেইল এবং প্লে বাটন শো হবে\n                    card.innerHTML = `\n                        <img src=\"${item.thumb}\" alt=\"${item.title}\" loading=\"lazy\">\n                        <div class=\"play-button-overlay\">\n                            <i class=\"fa-solid fa-play\"><\/i>\n                        <\/div>\n                    `;\n                    card.onclick = () => openVideo(item.url);\n                }\n\n                galleryGrid.appendChild(card);\n            });\n        }\n\n        \/\/ ফুল স্ক্রিন ফটো ওপেন সিস্টেম\n        function openPhoto(url) {\n            modalBody.innerHTML = `<img id=\"targetMedia\" src=\"${url}\" alt=\"Full View\">`;\n            mediaModal.classList.add('active');\n            downloadBtn.onclick = () => downloadFile(url, 'photo.jpg');\n        }\n\n        \/\/ ফুল স্ক্রিন ভিডিও ওপেন ও অটো-প্লে সিস্টেম\n        function openVideo(url) {\n            modalBody.innerHTML = `\n                <video id=\"targetMedia\" controls autoplay>\n                    <source src=\"${url}\" type=\"video\/mp4\">\n                    আপনার ব্রাউজারটি ভিডিও সাপোর্ট করে না।\n                <\/video>\n            `;\n            mediaModal.classList.add('active');\n            downloadBtn.onclick = () => downloadFile(url, 'video.mp4');\n        }\n\n        \/\/ ফুল স্ক্রিন মোড বন্ধ করা এবং ভিডিও পজ করা\n        function closeModal() {\n            const media = document.getElementById('targetMedia');\n            if(media && media.tagName === 'VIDEO') {\n                media.pause(); \/\/ মোডাল বন্ধ হলে ব্যাকগ্রাউন্ডে যেন গান বা ভিডিও না বাজে\n            }\n            mediaModal.classList.remove('active');\n        }\n\n        \/\/ এডভান্সড ব্যাকগ্রাউন্ড ফাইল ডাউনলোডার (সরাসরি গ্যালারিতে সেভ করার জন্য)\n        async function downloadFile(fileUrl, fileName) {\n            try {\n                downloadBtn.innerHTML = `<i class=\"fa-solid fa-spinner fa-spin\"><\/i> প্রসেসিং হচ্ছে...`;\n                \n                const response = await fetch(fileUrl);\n                const blob = await response.blob();\n                const blobUrl = URL.createObjectURL(blob);\n\n                const tempLink = document.createElement('a');\n                tempLink.href = blobUrl;\n                tempLink.download = `Premium_Media_${Date.now()}_${fileName}`;\n                document.body.appendChild(tempLink);\n                tempLink.click();\n                \n                document.body.removeChild(tempLink);\n                URL.revokeObjectURL(blobUrl);\n\n                downloadBtn.innerHTML = `<i class=\"fa-solid fa-circle-check\"><\/i> সেভ কমপ্লিট!`;\n                setTimeout(() => {\n                    downloadBtn.innerHTML = `<i class=\"fa-solid fa-circle-down\"><\/i> গ্যালারিতে সেভ করুন`;\n                }, 2000);\n            } catch (error) {\n                alert(\"ডাউনলোড করতে কিছুটা সমস্যা হচ্ছে। ফাইলটি সরাসরি ওপেন করে লং প্রেস করে সেভ করুন।\");\n                downloadBtn.innerHTML = `<i class=\"fa-solid fa-circle-down\"><\/i> গ্যালারিতে সেভ করুন`;\n            }\n        }\n\n        \/\/ লাইভ সার্চ সিস্টেম\n        searchInput.addEventListener('input', (e) => {\n            const query = e.target.value.toLowerCase();\n            const currentList = currentType === 'photo' ? allPhotos : allVideos;\n            const filtered = currentList.filter(item => item.title.includes(query));\n            renderMedia(filtered);\n        });\n\n        \/\/ ইনিশিয়াল রান\n        generatePhotos();\n        renderMedia(allPhotos); \/\/ প্রথমে ফটো দেখাবে\n\n    <\/script>\n<\/body>\n<\/html>\n","icon":"\/9j\/4AAQSkZJRgABAQAAAQABAAD\\/bAEMADQkKCwoIDQsKCw4ODQ8TIBUTEhITJxweFyAuKTEwLiktLDM6Sj4zNkY3LC1AV0FGTE5SU1IyPlphWlBgSlFST\/\/bAEMBDg4OExETJhUVJk81LTVPT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT\/\/AABEIAGAAYAMBIgACEQEDEQH\/xAAbAAACAgMBAAAAAAAAAAAAAAABAgAEAwUGB\/\/EADQQAAIBAwEFBQYFBQAAAAAAAAABAgMEEQUGEiExMhMiQVFxFmGRobLRI0JUgZMUJLHB4f\/EABgBAAMBAQAAAAAAAAAAAAAAAAABAgME\/8QAHxEBAAIBBAMBAAAAAAAAAAAAAAECAxESIVEEMTJh\/9oADAMBAAIRAxEAPwDpGAYVnaoGKOxWMigYW0ByXmMgIBtEygISEIAQhCAFkVjAJWU0m0euU9GtIzce0q1HuwhvYz5v0X+0buXBM8r20uJ19oq0JY3aMYwjjyxvf5bIyW2wUlrbW61UqOcbmNNP8kKccL4pv5ie1Ot\/rn\/FD7GmDhnPut2Tce1Ot\/rX\\/S8X0oXVrSrr8SCbXJ+KKFD+q0m9p3dnV3alPO5UUU8ZWHwfDkzaTrUcN9rB+jyValaEuEVvZ+Brk8eMkfp3rWWvup3OoXdS4uakqteq8ynLx+yHpafT51e+\/LkizCKXJYM0UTi8StObcyitGbT6cKdxBQhGKzySx4HTx6Uc7Zr+5h6nRR6UGb6TkjkSEIZM1wAzAQ1JNZiziNdoSp6nOT5VEmuH7Hcs1OradC7p8eElyl5GmK+y2pS4+KMsUXXpNxCTXda\/cK064XhH4nZOanZxorxRlijMrGsvBGSFnVzjBM5adtItBrGDlcRx4G\/S7qKdja9ksvmy8c17bp1Y3ndJSBYCULwowGZtigayMAZMTpRfgL2MPIygGli7KHkDsorwMrAAJjBBmKMisAzAxk\/\/2Q==","splash":"\/9j\/4AAQSkZJRgABAQAAAQABAAD\\/bAEMAEAsMDgwKEA4NDhIREBMYKBoYFhYYMSMlHSg6Mz08OTM4N0BIXE5ARFdFNzhQbVFXX2JnaGc+TXF5cGR4XGVnY\/\/bAEMBERISGBUYLxoaL2NCOEJjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY\/\/AABEIAZAA8AMBIgACEQEDEQH\/xAAbAAEBAAMBAQEAAAAAAAAAAAAAAQIDBAUGB\/\/EAEEQAQEAAQMBAwcJAwoHAAAAAAABAgMEETEFEiEGEzJBUXGxFCJSYXJzkZKhFiRUByU0NUJTgbLB0SMzYoLC4fH\/xAAZAQEBAQEBAQAAAAAAAAAAAAAAAQIEAwX\/xAAhEQEBAAICAgIDAQAAAAAAAAAAAQIRAzESIRNRBEFhIv\/aAAwDAQACEQMRAD8A95FR1tIKCIACAAgCoIqAIqAACACgAAAAAAAAAAADcijLaACIAAioCCoqCKAgAIAIAKAAAAAAAAAAAANwDLaAAIqCCKAiKigAIgAJRUAAEAFAAAAAAAAAAG4VGWxFQBFBEABASqAlqciKJynIMkTlOQZInJyIonJyoyE5UAAAAAAAAG9FRlsRQEAEQAErG1bWrPLgC5Mbm8PtPyj22zzy0tOXX1Z4WY3iT\/F5V8rdfn+jaf5qxc5EfY99O++P\/a3X\/htP81P2t3H8Np\/jT5IPsO+d98d+1m4\/htP81P2s1\/4bT\/NT5