{"code":"<!DOCTYPE html>\n<html lang=\"bn\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\n    <title>আল্ট্রা স্মার্ট মিডিয়া ও প্রোফাইল গ্যালারি<\/title>\n    <link rel=\"stylesheet\" href=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/font-awesome\/6.4.0\/css\/all.min.css\">\n    <style>\n        @import url('https:\/\/fonts.googleapis.com\/css2?family=Hind+Siliguri:wght@400;600;700&family=Poppins:wght@400;600;700&display=swap');\n\n        \/* --- প্রফেশনাল থিম ইঞ্জিন --- *\/\n        :root {\n            transition: all 0.5s ease;\n        }\n\n        \/* ১. ফটো গ্যালারি (ডিপ ব্লু \/ ডার্ক মোড) *\/\n        body.theme-photo {\n            --bg-color: #0f172a;\n            --text-main: #f8fafc;\n            --text-muted: #94a3b8;\n            --card-bg: #1e293b;\n            --card-border: rgba(59, 130, 246, 0.2);\n            --accent-color: #3b82f6;\n            --accent-gradient: linear-gradient(135deg, #3b82f6, #8b5cf6);\n        }\n\n        \/* ২. প্রোফাইল গ্যালারি (প্রিমিয়াম এমারেল্ড সবুজ) *\/\n        body.theme-profile {\n            --bg-color: #022c22;\n            --text-main: #ecfdf5;\n            --text-muted: #6ee7b7;\n            --card-bg: #064e3b;\n            --card-border: rgba(16, 185, 129, 0.3);\n            --accent-color: #10b981;\n            --accent-gradient: linear-gradient(135deg, #059669, #10b981);\n        }\n\n        \/* ৩. ভিডিও গ্যালারি (লাইট ও ক্লিন) *\/\n        body.theme-video {\n            --bg-color: #f8fafc;\n            --text-main: #0f172a;\n            --text-muted: #64748b;\n            --card-bg: #ffffff;\n            --card-border: rgba(226, 232, 240, 1);\n            --accent-color: #ef4444;\n            --accent-gradient: linear-gradient(135deg, #ef4444, #f97316);\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Hind Siliguri', 'Poppins', sans-serif;\n        }\n\n        body {\n            background: var(--bg-color);\n            color: var(--text-main);\n            min-height: 100vh;\n            padding: 20px 15px;\n            overflow-x: hidden;\n            transition: background 0.5s ease, color 0.5s ease;\n        }\n\n        \/* হেডার ও ড্যাশবোর্ড *\/\n        header h1 {\n            text-align: center;\n            font-size: 2.2rem;\n            font-weight: 700;\n            margin-bottom: 20px;\n            background: var(--accent-gradient);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n        }\n\n        .stats-dashboard {\n            max-width: 900px;\n            margin: 0 auto 30px;\n            background: var(--card-bg);\n            border: 1px solid var(--card-border);\n            border-radius: 20px;\n            padding: 20px;\n            display: flex;\n            justify-content: space-around;\n            flex-wrap: wrap;\n            gap: 15px;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.1);\n            transition: all 0.5s ease;\n        }\n\n        .stat-item {\n            text-align: center;\n            flex: 1;\n        }\n\n        .stat-item p {\n            font-size: 0.9rem;\n            color: var(--text-muted);\n            margin-bottom: 5px;\n        }\n\n        .stat-item span {\n            font-size: 1.8rem;\n            font-weight: 700;\n            color: var(--accent-color);\n        }\n\n        \/* ট্যাব কন্ট্রোলার *\/\n        .tabs {\n            display: flex;\n            justify-content: center;\n            gap: 15px;\n            margin-bottom: 25px;\n            flex-wrap: wrap;\n        }\n\n        .tab-btn {\n            padding: 12px 25px;\n            font-size: 1rem;\n            font-weight: 600;\n            border: 1px solid var(--card-border);\n            border-radius: 30px;\n            background: var(--card-bg);\n            color: var(--text-main);\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            gap: 8px;\n            transition: all 0.3s ease;\n        }\n\n        .tab-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 5px 15px rgba(0,0,0,0.1);\n        }\n\n        .tab-btn.active {\n            background: var(--accent-gradient);\n            color: #fff;\n            border-color: transparent;\n            box-shadow: 0 8px 20px rgba(0,0,0,0.2);\n        }\n\n        \/* সার্চ বার *\/\n        .search-box {\n            max-width: 600px;\n            margin: 0 auto 30px;\n            position: relative;\n        }\n\n        .search-box input {\n            width: 100%;\n            padding: 15px 20px 15px 50px;\n            border-radius: 30px;\n            background: var(--card-bg);\n            border: 1px solid var(--card-border);\n            color: var(--text-main);\n            font-size: 1rem;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 15px rgba(0,0,0,0.05);\n        }\n\n        .search-box input:focus {\n            outline: none;\n            border-color: var(--accent-color);\n            box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.2);\n        }\n\n        .search-box i {\n            position: absolute;\n            left: 20px;\n            top: 50%;\n            transform: translateY(-50%);\n            color: var(--accent-color);\n            font-size: 1.2rem;\n        }\n\n        \/* গ্যালারি গ্রিড *\/\n        .gallery {\n            display: grid;\n            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));\n            gap: 20px;\n            max-width: 1200px;\n            margin: 0 auto;\n        }\n\n        @media (max-width: 600px) {\n            .gallery {\n                grid-template-columns: repeat(2, 1fr);\n                gap: 10px;\n            }\n        }\n\n        .gallery-card {\n            position: relative;\n            border-radius: 16px;\n            overflow: hidden;\n            aspect-ratio: 1\/1;\n            background: var(--card-bg);\n            border: 1px solid var(--card-border);\n            cursor: pointer;\n            box-shadow: 0 5px 15px rgba(0,0,0,0.1);\n            transition: all 0.4s ease;\n        }\n\n        .gallery-card:hover {\n            transform: translateY(-5px) scale(1.02);\n            box-shadow: 0 12px 25px rgba(0,0,0,0.2);\n            border-color: var(--accent-color);\n        }\n\n        .gallery-card img, .gallery-card video-thumb {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            opacity: 0;\n            transition: opacity 0.5s ease;\n        }\n\n        .gallery-card img.loaded {\n            opacity: 1;\n        }\n\n        \/* ভিডিও প্লে আইকন *\/\n        .play-btn-overlay {\n            position: absolute;\n            inset: 0;\n            background: rgba(0,0,0,0.3);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            opacity: 0.8;\n            transition: 0.3s;\n        }\n\n        .gallery-card:hover .play-btn-overlay {\n            background: rgba(0,0,0,0.5);\n            opacity: 1;\n        }\n\n        .play-btn-overlay i {\n            font-size: 3rem;\n            color: white;\n            filter: drop-shadow(0 2px 5px rgba(0,0,0,0.5));\n        }\n\n        \/* মোডাল (লাইটবক্স) *\/\n        .modal {\n            position: fixed;\n            inset: 0;\n            background: rgba(0, 0, 0, 0.9);\n            backdrop-filter: blur(15px);\n            z-index: 1000;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            opacity: 0;\n            pointer-events: none;\n            transition: opacity 0.3s ease;\n            padding: 20px;\n        }\n\n        .modal.active {\n            opacity: 1;\n            pointer-events: auto;\n        }\n\n        .modal-content {\n            max-width: 90vw;\n            max-height: 75vh;\n            border-radius: 12px;\n            box-shadow: 0 10px 40px rgba(0,0,0,0.5);\n        }\n\n        .modal-close {\n            position: absolute;\n            top: 20px;\n            right: 25px;\n            font-size: 2.5rem;\n            color: white;\n            cursor: pointer;\n            transition: 0.3s;\n        }\n\n        .modal-close:hover {\n            color: #ef4444;\n            transform: scale(1.1);\n        }\n\n        .download-btn {\n            margin-top: 25px;\n            padding: 12px 35px;\n            background: var(--accent-gradient);\n            color: white;\n            border: none;\n            border-radius: 30px;\n            font-size: 1.1rem;\n            font-weight: 600;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            gap: 10px;\n            box-shadow: 0 5px 15px rgba(0,0,0,0.3);\n        }\n    <\/style>\n<\/head>\n<body class=\"theme-photo\">\n\n    <header>\n        <h1>স্মার্ট মিডিয়া প্রো<\/h1>\n    <\/header>\n\n    <div class=\"stats-dashboard\">\n        <div class=\"stat-item\">\n            <p><i class=\"fa-solid fa-images\"><\/i> মোট কালেকশন<\/p>\n            <span id=\"totalCount\">0<\/span>\n        <\/div>\n        <div class=\"stat-item\">\n            <p><i class=\"fa-solid fa-eye\"><\/i> বর্তমানে দেখাচ্ছে<\/p>\n            <span id=\"currentCount\">0<\/span>\n        <\/div>\n    <\/div>\n\n    <div class=\"tabs\">\n        <button class=\"tab-btn active\" id=\"btn-photo\" onclick=\"switchTab('photo')\">\n            <i class=\"fa-solid fa-image\"><\/i> ফটো গ্যালারি\n        <\/button>\n        <button class=\"tab-btn\" id=\"btn-profile\" onclick=\"switchTab('profile')\">\n            <i class=\"fa-solid fa-user-shield\"><\/i> প্রোফাইল পিকচার\n        <\/button>\n        <button class=\"tab-btn\" id=\"btn-video\" onclick=\"switchTab('video')\">\n            <i class=\"fa-solid fa-play-circle\"><\/i> ভিডিও গ্যালারি\n        <\/button>\n    <\/div>\n\n    <div class=\"search-box\">\n        <i class=\"fa-solid fa-magnifying-glass\"><\/i>\n        <input type=\"text\" id=\"searchInput\" placeholder=\"সার্চ করুন (যেমন: car, প্রকৃতি, boy, girl, gaming, শহর)...\">\n    <\/div>\n\n    <div class=\"gallery\" id=\"galleryGrid\"><\/div>\n\n    <div class=\"modal\" id=\"mediaModal\">\n        <span class=\"modal-close\" onclick=\"closeModal()\"><i class=\"fa-solid fa-times\"><\/i><\/span>\n        <div id=\"modalBody\"><\/div>\n        <button class=\"download-btn\" id=\"downloadBtn\" onclick=\"downloadCurrentMedia()\">\n            <i class=\"fa-solid fa-download\"><\/i> সেভ করুন\n        <\/button>\n    <\/div>\n\n    <script>\n        let currentCategory = 'photo';\n        let currentMediaUrl = '';\n\n        \/\/ গ্যারান্টিড ওয়ার্কিং ডাটাবেস (HD Images)\n        const mediaDatabase = [\n            \/\/ --- ফটো গ্যালারি ---\n            { type: 'photo', tags: ['গাড়ি', 'car', 'supercar'], url: 'https:\/\/images.unsplash.com\/photo-1494976388531-d1058494cdd8?auto=format&fit=crop&w=600&q=80' },\n            { type: 'photo', tags: ['গাড়ি', 'car', 'bmw'], url: 'https:\/\/images.unsplash.com\/photo-1555215695-3004980ad54e?auto=format&fit=crop&w=600&q=80' },\n            { type: 'photo', tags: ['প্রকৃতি', 'nature', 'landscape'], url: 'https:\/\/images.unsplash.com\/photo-1472214103451-9374bd1c798e?auto=format&fit=crop&w=600&q=80' },\n            { type: 'photo', tags: ['প্রকৃতি', 'nature', 'mountain'], url: 'https:\/\/images.unsplash.com\/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=600&q=80' },\n            { type: 'photo', tags: ['শহর', 'city', 'night'], url: 'https:\/\/images.unsplash.com\/photo-1477959858617-67f85cf4f1df?auto=format&fit=crop&w=600&q=80' },\n            { type: 'photo', tags: ['শহর', 'cyberpunk', 'neon'], url: 'https:\/\/images.unsplash.com\/photo-1555949963-aa79dcee981c?auto=format&fit=crop&w=600&q=80' },\n            { type: 'photo', tags: ['flower', 'ফুল', 'গোলাপ'], url: 'https:\/\/images.unsplash.com\/photo-1490750967868-88cb45ce8aca?auto=format&fit=crop&w=600&q=80' },\n            { type: 'photo', tags: ['space', 'মহাকাশ', 'galaxy'], url: 'https:\/\/images.unsplash.com\/photo-1462331940025-496dfbfc7564?auto=format&fit=crop&w=600&q=80' },\n\n            \/\/ --- প্রোফাইল গ্যালারি (ছেলে, মেয়ে, গেমিং) ---\n            { type: 'profile', tags: ['ছেলে', 'boy', 'smart'], url: 'https:\/\/images.unsplash.com\/photo-1506794778202-cad84cf45f1d?auto=format&fit=crop&w=600&q=80' },\n            { type: 'profile', tags: ['ছেলে', 'man', 'attitude'], url: 'https:\/\/images.unsplash.com\/photo-1519085360753-af0119f7cbe7?auto=format&fit=crop&w=600&q=80' },\n            { type: 'profile', tags: ['মেয়ে', 'girl', 'beautiful'], url: 'https:\/\/images.unsplash.com\/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=600&q=80' },\n            { type: 'profile', tags: ['মেয়ে', 'girl', 'cute'], url: 'https:\/\/images.unsplash.com\/photo-1524504388940-b1c1722653e1?auto=format&fit=crop&w=600&q=80' },\n            { type: 'profile', tags: ['গেমিং', 'gaming', 'avatar'], url: 'https:\/\/images.unsplash.com\/photo-1542751371-adc38448a05e?auto=format&fit=crop&w=600&q=80' },\n            { type: 'profile', tags: ['গেমিং', 'gaming', 'hacker'], url: 'https:\/\/images.unsplash.com\/photo-1526374965328-7f61d4dc18c5?auto=format&fit=crop&w=600&q=80' },\n            { type: 'profile', tags: ['anime', 'এনিমে', 'art'], url: 'https:\/\/images.unsplash.com\/photo-1607604276583-eef5d076aa5f?auto=format&fit=crop&w=600&q=80' },\n            { type: 'profile', tags: ['mask', 'মাস্ক', 'anonymous'], url: 'https:\/\/images.unsplash.com\/photo-1511367461989-f85a21fda167?auto=format&fit=crop&w=600&q=80' },\n\n            \/\/ --- ভিডিও গ্যালারি (ডেমো ভিডিও) ---\n            { type: 'video', tags: ['nature', 'প্রকৃতি'], thumb: 'https:\/\/images.unsplash.com\/photo-1447752875215-b2761acb3c5d?auto=format&fit=crop&w=600&q=80', url: 'https:\/\/vjs.zencdn.net\/v\/oceans.mp4' },\n            { type: 'video', tags: ['car', 'গাড়ি'], thumb: 'https:\/\/images.unsplash.com\/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&w=600&q=80', url: 'https:\/\/media.w3.org\/2010\/05\/bunny\/movie.mp4' },\n            { type: 'video', tags: ['city', 'শহর'], thumb: 'https:\/\/images.unsplash.com\/photo-1449844908441-8829872d2607?auto=format&fit=crop&w=600&q=80', url: 'https:\/\/media.w3.org\/2010\/05\/sintel\/trailer_hd.mp4' }\n        ];\n\n        document.getElementById('totalCount').innerText = mediaDatabase.length;\n\n        \/\/ গ্যালারি রেন্ডার ফাংশন\n        function renderGallery(searchQuery = '') {\n            const grid = document.getElementById('galleryGrid');\n            grid.innerHTML = '';\n            \n            const filteredData = mediaDatabase.filter(item => {\n                const matchType = item.type === currentCategory;\n                const matchSearch = searchQuery === '' || item.tags.some(tag => tag.toLowerCase().includes(searchQuery.toLowerCase()));\n                return matchType && matchSearch;\n            });\n\n            document.getElementById('currentCount').innerText = filteredData.length;\n\n            if (filteredData.length === 0) {\n                grid.innerHTML = `<h3 style=\"grid-column: 1\/-1; text-align:center; padding: 40px; color: var(--text-muted);\">কোনো রেজাল্ট পাওয়া যায়নি! অন্য কিছু লিখে খুঁজুন।<\/h3>`;\n                return;\n            }\n\n            filteredData.forEach(item => {\n                const card = document.createElement('div');\n                card.className = 'gallery-card';\n                \n                const imgSrc = item.type === 'video' ? item.thumb : item.url;\n                \n                let innerHTML = `<img src=\"${imgSrc}\" onload=\"this.classList.add('loaded')\" alt=\"${item.tags[0]}\">`;\n                \n                if (item.type === 'video') {\n                    innerHTML += `<div class=\"play-btn-overlay\"><i class=\"fa-solid fa-circle-play\"><\/i><\/div>`;\n                    card.onclick = () => openModal(item.url, 'video');\n                } else {\n                    card.onclick = () => openModal(item.url, 'photo');\n                }\n                \n                card.innerHTML = innerHTML;\n                grid.appendChild(card);\n            });\n        }\n\n        \/\/ থিম ও ট্যাব পরিবর্তন\n        function switchTab(tabName) {\n            currentCategory = tabName;\n            \n            \/\/ বডির থিম ক্লাস চেঞ্জ\n            document.body.className = `theme-${tabName}`;\n            \n            \/\/ বাটন অ্যাক্টিভ কালার চেঞ্জ\n            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));\n            document.getElementById(`btn-${tabName}`).classList.add('active');\n            \n            document.getElementById('searchInput').value = '';\n            renderGallery();\n        }\n\n        \/\/ সার্চ বক্স ইভেন্ট\n        document.getElementById('searchInput').addEventListener('input', (e) => {\n            renderGallery(e.target.value);\n        });\n\n        \/\/ লাইটবক্স \/ মোডাল ওপেন\n        function openModal(url, type) {\n            currentMediaUrl = url;\n            const modalBody = document.getElementById('modalBody');\n            \n            if (type === 'video') {\n                modalBody.innerHTML = `<video src=\"${url}\" class=\"modal-content\" controls autoplay><\/video>`;\n            } else {\n                modalBody.innerHTML = `<img src=\"${url}\" class=\"modal-content\">`;\n            }\n            \n            document.getElementById('mediaModal').classList.add('active');\n        }\n\n        \/\/ মোডাল ক্লোজ\n        function closeModal() {\n            document.getElementById('mediaModal').classList.remove('active');\n            document.getElementById('modalBody').innerHTML = ''; \/\/ ভিডিও স্টপ করার জন্য\n        }\n\n        \/\/ ডাউনলোড সিস্টেম (অ্যাডভান্সড)\n        async function downloadCurrentMedia() {\n            const btn = document.getElementById('downloadBtn');\n            const originalText = btn.innerHTML;\n            btn.innerHTML = `<i class=\"fa-solid fa-spinner fa-spin\"><\/i> সেভ হচ্ছে...`;\n            \n            try {\n                const response = await fetch(currentMediaUrl);\n                const blob = await response.blob();\n                const url = window.URL.createObjectURL(blob);\n                const a = document.createElement('a');\n                a.href = url;\n                a.download = `SmartMedia_${Date.now()}`;\n                document.body.appendChild(a);\n                a.click();\n                window.URL.revokeObjectURL(url);\n                \n                btn.innerHTML = `<i class=\"fa-solid fa-check\"><\/i> সেভ হয়েছে!`;\n            } catch (error) {\n                \/\/ আনস্প্ল্যাশ ডাইরেক্ট ডাউনলোড ব্লক করলে এটি কাজ করবে\n                alert('সরাসরি সেভ করতে সমস্যা হচ্ছে! দয়া করে ছবির ওপর চেপে ধরে (Long Press) \"Download Image\" এ ক্লিক করুন।');\n                window.open(currentMediaUrl, '_blank'); \n            }\n            \n            setTimeout(() => { btn.innerHTML = originalText; }, 3000);\n        }\n\n        \/\/ অ্যাপ স্টার্ট\n        renderGallery();\n    <\/script>\n<\/body>\n<\/html>","icon":"\/9j\/4AAQSkZJRgABAQAAAQABAAD\\/bAEMADQkKCwoIDQsKCw4ODQ8TIBUTEhITJxweFyAuKTEwLiktLDM6Sj4zNkY3LC1AV0FGTE5SU1IyPlphWlBgSlFST\/\/bAEMBDg4OExETJhUVJk81LTVPT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT\/\/AABEIAGAAYAMBIgACEQEDEQH\/xAAbAAACAwEBAQAAAAAAAAAAAAAFBgIDBAEHAP\/EAEEQAAEDAgIDCwkGBgMAAAAAAAEAAgMEEQUhEjFBBgcTFlFhcYOjwuEiM1JUZIGRscEUIzJigqFCU2Ny8PGistH\/xAAZAQACAwEAAAAAAAAAAAAAAAACBAABBQP\/xAAqEQABBAECBAUFAQAAAAAAAAABAAIDBBESISIjMUEUUYGhsRMyQnHRYf\/aAAwDAQACEQMRAD8A86VkEEtRJwcEZe7m2L6ngfU1DIIh5TzYcycqSkipYWxRNsBrO0nlKEnC16lUznJOAEAi3Pzu87KxnRdxVvFw+td