{"code":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Modern Translator UI<\/title>\n    \n    <!-- Google Fonts -->\n    <link href=\"https:\/\/fonts.googleapis.com\/css2?family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <!-- FontAwesome Icons -->\n    <link rel=\"stylesheet\" href=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/font-awesome\/6.4.0\/css\/all.min.css\">\n\n    <style>\n        \/* ============================\n           1. Modern CSS Reset & Variables\n           ============================ *\/\n        :root {\n            --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            --glass-bg: rgba(255, 255, 255, 0.95);\n            --input-bg: #f8f9fa;\n            --border-color: #e2e8f0;\n            --text-main: #1e293b;\n            --text-light: #64748b;\n            --accent: #6366f1;\n            --radius: 16px;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Inter', sans-serif;\n        }\n\n        body {\n            min-height: 100vh;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            background: var(--primary-gradient);\n            padding: 20px;\n        }\n\n        \/* ============================\n           2. Main Card Design\n           ============================ *\/\n        .container {\n            background: var(--glass-bg);\n            width: 100%;\n            max-width: 900px;\n            border-radius: 24px;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);\n            padding: 30px;\n            position: relative;\n            overflow: hidden;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 30px;\n        }\n\n        header h2 {\n            font-size: 1.8rem;\n            color: var(--text-main);\n            font-weight: 700;\n            letter-spacing: -0.5px;\n        }\n\n        \/* ============================\n           3. Improved Language Controls\n           ============================ *\/\n        .translation-wrapper {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            background: #fff;\n            padding: 8px;\n            border-radius: 12px;\n            box-shadow: 0 4px 15px rgba(0,0,0,0.05);\n            border: 1px solid var(--border-color);\n        }\n\n        \/* Custom Select Wrapper *\/\n        .select-container {\n            position: relative;\n            flex: 1;\n            width: 100%;\n        }\n\n        .select-container select {\n            width: 100%;\n            appearance: none; \/* Hide default arrow *\/\n            -webkit-appearance: none;\n            background: transparent;\n            padding: 12px 40px 12px 15px;\n            border: 1px solid transparent;\n            border-radius: 8px;\n            font-size: 1rem;\n            font-weight: 600;\n            color: var(--text-main);\n            cursor: pointer;\n            outline: none;\n            transition: all 0.3s ease;\n        }\n\n        .select-container select:hover {\n            background-color: #f1f5f9;\n        }\n\n        .select-container select:focus {\n            border-color: var(--accent);\n            background-color: #eef2ff;\n        }\n\n        \/* Custom Arrow Icon *\/\n        .select-container i {\n            position: absolute;\n            right: 15px;\n            top: 50%;\n            transform: translateY(-50%);\n            color: var(--text-light);\n            pointer-events: none;\n            font-size: 0.8rem;\n            transition: transform 0.3s;\n        }\n\n        .select-container select:focus + i {\n            transform: translateY(-50%) rotate(180deg);\n            color: var(--accent);\n        }\n\n        \/* Swap Button Design *\/\n        .swap-btn {\n            width: 45px;\n            height: 45px;\n            min-width: 45px;\n            border-radius: 50%;\n            background: #f1f5f9;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            cursor: pointer;\n            color: var(--text-light);\n            margin: 0 15px;\n            transition: all 0.3s ease;\n            border: 1px solid transparent;\n        }\n\n        .swap-btn:hover {\n            background: var(--accent);\n            color: white;\n            transform: rotate(180deg) scale(1.1);\n            box-shadow: 0 5px 15px rgba(99, 102, 241, 0.3);\n        }\n\n        \/* ============================\n           4. Input & Output Boxes\n           ============================ *\/\n        .text-areas {\n            display: flex;\n            gap: 20px;\n        }\n\n        .box {\n            flex: 1;\n            position: relative;\n            background: var(--input-bg);\n            border-radius: var(--radius);\n            border: 1px solid var(--border-color);\n            padding: 20px;\n            transition: border-color 0.3s ease, box-shadow 0.3s ease;\n        }\n\n        .box:focus-within {\n            border-color: var(--accent);\n            background: white;\n            box-shadow: 0 4px 20px rgba(0,0,0,0.05);\n        }\n\n        textarea {\n            width: 100%;\n            height: 250px;\n            border: none;\n            outline: none;\n            background: transparent;\n            font-size: 1.1rem;\n            line-height: 1.6;\n            color: var(--text-main);\n            resize: none;\n        }\n\n        textarea::placeholder {\n            color: #cbd5e1;\n        }\n\n        \/* Copy Button *\/\n        .copy-btn {\n            position: absolute;\n            bottom: 15px;\n            right: 15px;\n            background: white;\n            border: 1px solid var(--border-color);\n            width: 35px;\n            height: 35px;\n            border-radius: 8px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: var(--text-light);\n            cursor: pointer;\n            transition: all 0.2s;\n            z-index: 10; \/* Ensure it's clickable *\/\n        }\n\n        .copy-btn:hover {\n            background: var(--accent);\n            color: white;\n            border-color: var(--accent);\n        }\n\n        .copy-btn:active {\n            transform: scale(0.95);\n        }\n\n        \/* ============================\n           5. Translate Button\n           ============================ *\/\n        .action-area {\n            margin-top: 25px;\n            text-align: center;\n        }\n\n        button.translate-btn {\n            background: var(--primary-gradient);\n            color: white;\n            font-size: 1.1rem;\n            padding: 16px 45px;\n            border: none;\n            border-radius: 50px;\n            font-weight: 600;\n            cursor: pointer;\n            box-shadow: 0 10px 20px rgba(118, 75, 162, 0.3);\n            transition: transform 0.2s, box-shadow 0.2s;\n            display: inline-flex;\n            align-items: center;\n            gap: 12px;\n        }\n\n        button.translate-btn:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 15px 30px rgba(118, 75, 162, 0.4);\n        }\n\n        button.translate-btn:active {\n            transform: scale(0.98);\n        }\n\n        \/* Spinner *\/\n        .spinner {\n            display: none;\n            width: 20px;\n            height: 20px;\n            border: 3px solid rgba(255,255,255,0.3);\n            border-top-color: white;\n            border-radius: 50%;\n            animation: spin 0.8s linear infinite;\n        }\n\n        @keyframes spin { to { transform: rotate(360deg); } }\n\n        \/* ============================\n           6. Toast Notification\n           ============================ *\/\n        #toast {\n            visibility: hidden;\n            min-width: 250px;\n            background-color: #1e293b;\n            color: #fff;\n            text-align: center;\n            border-radius: 50px;\n            padding: 14px 25px;\n            position: fixed;\n            z-index: 100;\n            bottom: 30px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-size: 0.95rem;\n            font-weight: 500;\n            box-shadow: 0 10px 20px rgba(0,0,0,0.2);\n            opacity: 0;\n            transition: opacity 0.3s, bottom 0.3s;\n        }\n\n        #toast.show {\n            visibility: visible;\n            opacity: 1;\n            bottom: 50px;\n        }\n\n        \/* Responsive Design *\/\n        @media (max-width: 768px) {\n            .text-areas {\n                flex-direction: column;\n            }\n            textarea {\n                height: 150px;\n            }\n            .controls {\n                flex-direction: row; \n                padding: 10px;\n            }\n            .swap-btn {\n                width: 35px;\n                height: 35px;\n                min-width: 35px;\n                margin: 0 8px;\n            }\n            .select-container select {\n                padding: 10px 30px 10px 10px;\n                font-size: 0.9rem;\n            }\n        }\n    <\/style>\n<\/head>\n<body>\n\n    <div class=\"container\">\n        <header>\n            <h2>Modern Translator<\/h2>\n        <\/header>\n\n        <div class=\"translation-wrapper\">\n            <!-- Language Controls -->\n            <div class=\"controls\">\n                <div class=\"select-container\">\n                    <select id=\"select-from\"><\/select>\n                    <i class=\"fa-solid fa-chevron-down\"><\/i>\n                <\/div>\n                \n                <div class=\"swap-btn\" title=\"Swap Languages\">\n                    <i class=\"fa-solid fa-arrow-right-arrow-left\"><\/i>\n                <\/div>\n                \n                <div class=\"select-container\">\n                    <select id=\"select-to\"><\/select>\n                    <i class=\"fa-solid fa-chevron-down\"><\/i>\n                <\/div>\n            <\/div>\n\n            <!-- Text Areas -->\n            <div class=\"text-areas\">\n                <!-- Input Box -->\n                <div class=\"box\">\n                    <textarea id=\"input-text\" placeholder=\"Type or paste text here...\"><\/textarea>\n                    <div class=\"copy-btn\" id=\"copy-from\" title=\"Copy Text\">\n                        <i class=\"fa-regular fa-copy\"><\/i>\n                    <\/div>\n                <\/div>\n\n                <!-- Output Box -->\n                <div class=\"box\">\n                    <textarea id=\"output-text\" placeholder=\"Translation will appear here...\" readonly><\/textarea>\n                    <div class=\"copy-btn\" id=\"copy-to\" title=\"Copy Translation\">\n                        <i class=\"fa-regular fa-copy\"><\/i>\n                    <\/div>\n                <\/div>\n            <\/div>\n        <\/div>\n\n        <div class=\"action-area\">\n            <button id=\"translate-btn\" class=\"translate-btn\">\n                <span>Translate Now<\/span>\n                <div class=\"spinner\"><\/div>\n            <\/button>\n        <\/div>\n    <\/div>\n\n    <!-- Toast Notification Element -->\n    <div id=\"toast\">Text copied to clipboard!<\/div>\n\n    <script>\n        \/\/ --- Configuration ---\n        const languages = {\n            \"en-GB\": \"English\",\n            \"bn-IN\": \"Bangla\",\n            \"hi-IN\": \"Hindi\",\n            \"ar-SA\": \"Arabic\",\n            \"fr-FR\": \"French\",\n            \"es-ES\": \"Spanish\",\n            \"de-DE\": \"German\",\n            \"zh-CN\": \"Chinese\",\n            \"ja-JP\": \"Japanese\",\n            \"pt-PT\": \"Portuguese\",\n            \"ru-RU\": \"Russian\"\n        };\n\n        \/\/ --- Select Elements ---\n        const selectFrom = document.getElementById(\"select-from\");\n        const selectTo = document.getElementById(\"select-to\");\n        const inputText = document.getElementById(\"input-text\");\n        const outputText = document.getElementById(\"output-text\");\n        const translateBtn = document.getElementById(\"translate-btn\");\n        const swapBtn = document.querySelector(\".swap-btn\");\n        const copyBtns = document.querySelectorAll(\".copy-btn\");\n        const spinner = document.querySelector(\".spinner\");\n        const btnText = translateBtn.querySelector(\"span\");\n        const toast = document.getElementById(\"toast\");\n\n        \/\/ --- 1. Populate Dropdowns ---\n        function populateLanguages() {\n            for (let code in languages) {\n                let selectedFrom = code === \"en-GB\" ? \"selected\" : \"\";\n                selectFrom.insertAdjacentHTML(\"beforeend\", `<option value=\"${code}\" ${selectedFrom}>${languages[code]}<\/option>`);\n\n                let selectedTo = code === \"bn-IN\" ? \"selected\" : \"\";\n                selectTo.insertAdjacentHTML(\"beforeend\", `<option value=\"${code}\" ${selectedTo}>${languages[code]}<\/option>`);\n            }\n        }\n        populateLanguages();\n\n        \/\/ --- 2. Translation Logic ---\n        async function translateText() {\n            let text = inputText.value.trim();\n            \n            if (!text) {\n                showToast(\"Please enter some text first!\", true);\n                return;\n            }\n\n            translateBtn.disabled = true;\n            btnText.innerText = \"Translating...\";\n            spinner.style.display = \"block\";\n            outputText.setAttribute(\"placeholder\", \"Translating...\");\n\n            let fromLang = selectFrom.value.split('-')[0];\n            let toLang = selectTo.value.split('-')[0];\n            const url = `https:\/\/api.mymemory.translated.net\/get?q=${encodeURIComponent(text)}&langpair=${fromLang}|${toLang}`;\n\n            try {\n                const res = await fetch(url);\n                const data = await res.json();\n                \n                if (data.responseData.translatedText) {\n                    outputText.value = data.responseData.translatedText;\n                } else {\n                    outputText.value = \"Translation failed.\";\n                }\n            } catch (err) {\n                console.error(err);\n                showToast(\"Network Error. Check internet connection.\", true);\n            } finally {\n                translateBtn.disabled = false;\n                btnText.innerText = \"Translate Now\";\n                spinner.style.display = \"none\";\n            }\n        }\n\n        \/\/ --- 3. IMPROVED COPY FUNCTION (Fixes Issue) ---\n        function copyToClipboard(text) {\n            if (!text) {\n                showToast(\"Nothing to copy!\", true);\n                return;\n            }\n            \n            \/\/ Method 1: Try Modern API first\n            if (navigator.clipboard && navigator.clipboard.writeText) {\n                navigator.clipboard.writeText(text)\n                    .then(() => showToast(\"Copied to clipboard!\"))\n                    .catch(err => {\n                        console.error(\"Async copy failed, trying fallback\", err);\n                        fallbackCopy(text);\n                    });\n            } else {\n                \/\/ Method 2: Fallback for older browsers or non-HTTPS\n                fallbackCopy(text);\n            }\n        }\n\n        \/\/ Fallback Copy Function\n        function fallbackCopy(text) {\n            try {\n                const textArea = document.createElement(\"textarea\");\n                textArea.value = text;\n                \n                \/\/ Make it invisible but part of DOM\n                textArea.style.position = \"fixed\";\n                textArea.style.left = \"-9999px\";\n                textArea.style.top = \"0\";\n                \n                document.body.appendChild(textArea);\n                textArea.focus();\n                textArea.select();\n\n                const successful = document.execCommand('copy');\n                document.body.removeChild(textArea);\n\n                if (successful) {\n                    showToast(\"Copied to clipboard!\");\n                } else {\n                    showToast(\"Failed to copy.\", true);\n                }\n            } catch (err) {\n                console.error(\"Fallback copy error\", err);\n                showToast(\"Failed to copy.\", true);\n            }\n        }\n\n        \/\/ --- 4. Event Listeners ---\n        translateBtn.addEventListener(\"click\", translateText);\n\n        swapBtn.addEventListener(\"click\", () => {\n            const tempText = inputText.value;\n            inputText.value = outputText.value;\n            outputText.value = tempText;\n\n            const tempLang = selectFrom.value;\n            selectFrom.value = selectTo.value;\n            selectTo.value = tempLang;\n        });\n\n        copyBtns.forEach(btn => {\n            btn.addEventListener(\"click\", () => {\n                if (btn.id === \"copy-from\") {\n                    copyToClipboard(inputText.value);\n                } else {\n                    copyToClipboard(outputText.value);\n                }\n            });\n        });\n\n        function showToast(message, isError = false) {\n            toast.innerText = message;\n            toast.style.backgroundColor = isError ? \"#ff416c\" : \"#1e293b\";\n            toast.className = \"show\";\n            setTimeout(() => { \n                toast.className = toast.className.replace(\"show\", \"\"); \n            }, 3000);\n        }\n\n        inputText.addEventListener(\"keyup\", (e) => {\n            if(e.ctrlKey && e.key === \"Enter\") translateText();\n        });\n\n    <\/script>\n<\/body>\n<\/html>","icon":"\/9j\/4AAQSkZJRgABAQAAAQABAAD\\/bAEMADQkKCwoIDQsKCw4ODQ8TIBUTEhITJxweFyAuKTEwLiktLDM6Sj4zNkY3LC1AV0FGTE5SU1IyPlphWlBgSlFST\/\/bAEMBDg4OExETJhUVJk81LTVPT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT\/\/AABEIAGAAYAMBIgACEQEDEQH\/xAAbAAEAAwEBAQEAAAAAAAAAAAAABQYHBAMCAf\/EADcQAAEDAgMFBQYEBwAAAAAAAAEAAgMEEQUSIQYTMUGBFCJRYXEVI0KRocEycrGyFlKCo9Hi8P\/EABoBAAIDAQEAAAAAAAAAAAAAAAADAgQFAQb\/xAAjEQACAgEEAgIDAAAAAAAAAAAAAQIDEQQFEkEhMVFxE0Kx\/9oADAMBAAIRAxEAPwCLREXszJCIiACIiACIvsMDZWtnD2NNi6w1ynW4B8uCG8AfCKVx2sw6rfC7D6YsJb7x7rh1xoARe3AXv5qKUKpuceTWDslh4CIimcCIiAC7sIwufFq0U8JDQBme88Gt+58lwq\/7E0PZ8KdUuHfqXX\/pGg+56qprb3TU5L30MphzlhnD\/A3jiX9j\/ZQ+PbPTYOyOXeiaF5y58uUh3ha60lcWMUQxDC56X4nt7utrOGo+oCx6dwuU1zllFudEWvCMthhlqJmwwMdJI82a1o1K0LE9nIMSpadr37qeGMM3jRe4HI+KpOFYnUYVUvkp2RF7hkO8be2qs1JtI6twuuirHRwVIheYnMJaHacBc8bq9rle5RlD0u\\/EZ6p1\/evJAPIch0FlpWB13tHCaepJu9zbP\/MND9dVlituwldklnoHnR\/vWcOI0P0t8itrcdOnQnH9f4VKJ4n57LlNEyeF8UrczHtLXDxBWWPjfhmKvilBvBIWnS1x4j1C1ZUbbqg3VZDXMb3ZhkeQPiHD5j9qo7Zbix1v1IdqI5jyXR0NjBAI1BXPidHv6CQAXc0Zm+oXpgEvacOaD+OI5D6cvp+ilREnSm6547QtRUkZ6i7MVpDR4hLDazb5macj\\/MNR9x1V3ESzaedvtGSopAYm74viFrZRe408tFfKHaPCqmna+WobBIR3o337p9ea0NfVNtWRXv2IpksYbIrbGgJp4q1jdYzkfYcjwPQ\/qqir7jmNYRJhFTC2oZM+RhaxjRfvcj0OvRUJWtulN1YmsYF3pcsoIiK+JCIiACIiACIiACIiACIiAP\/9k=","splash":"\/9j\/4AAQSkZJRgABAQAAAQABAAD\\/bAEMAEAsMDgwKEA4NDhIREBMYKBoYFhYYMSMlHSg6Mz08OTM4N0BIXE5ARFdFNzhQbVFXX2JnaGc+TXF5cGR4XGVnY\/\/bAEMBERISGBUYLxoaL2NCOEJjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY2NjY\/\/AABEIAZAA8AMBIgACEQEDEQH\/xAAaAAEBAQEBAQEAAAAAAAAAAAAAAQIDBAUG\/8QAJBABAQEAAgEEAgMBAQAAAAAAABEBITFBAlFhcRKBMkKRIqH\/xAAYAQEBAQEBAAAAAAAAAAAAAAAAAQIEA\/\/EABYRAQEBAAAAAAA