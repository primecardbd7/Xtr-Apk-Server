{"code":"<!DOCTYPE html>\n<html lang=\"bn\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\n    <title>আল্ট্রা স্মার্ট মিডিয়া ও প্রোফাইল গ্যালারি<\/title>\n    <link rel=\"stylesheet\" href=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/font-awesome\/6.4.0\/css\/all.min.css\">\n    <style>\n        @import url('https:\/\/fonts.googleapis.com\/css2?family=Hind+Siliguri:wght@400;600;700&family=Poppins:wght@400;600;700&display=swap');\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Hind Siliguri', 'Poppins', sans-serif;\n        }\n\n        body {\n            background: #060913;\n            color: #f1f5f9;\n            min-height: 100vh;\n            padding: 15px;\n            overflow-x: hidden;\n        }\n\n        \/* Top Stats Dashboard *\/\n        .stats-dashboard {\n            max-width: 1200px;\n            margin: 0 auto 20px;\n            background: rgba(15, 23, 42, 0.6);\n            border: 1px solid rgba(56, 189, 248, 0.15);\n            backdrop-filter: blur(12px);\n            border-radius: 16px;\n            padding: 15px;\n            display: flex;\n            justify-content: space-around;\n            align-items: center;\n            flex-wrap: wrap;\n            gap: 10px;\n            box-shadow: 0 8px 32px rgba(0,0,0,0.5);\n        }\n\n        .stat-item {\n            text-align: center;\n            flex: 1;\n            min-width: 100px;\n        }\n\n        .stat-item p {\n            font-size: 0.85rem;\n            color: #94a3b8;\n            margin-bottom: 4px;\n        }\n\n        .stat-item span {\n            font-size: 1.4rem;\n            font-weight: 700;\n            color: #38bdf8;\n        }\n\n        .stat-item .highlight { color: #22c55e; }\n        .stat-item .current-view { color: #a855f7; }\n\n        header h1 {\n            text-align: center;\n            font-size: 1.8rem;\n            font-weight: 700;\n            margin-bottom: 20px;\n            background: linear-gradient(to right, #38bdf8, #a855f7, #f43f5e);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n        }\n\n        \/* Navigation Tabs *\/\n        .media-type-switcher {\n            display: flex;\n            justify-content: center;\n            gap: 8px;\n            margin-bottom: 20px;\n            flex-wrap: wrap;\n        }\n\n        .type-btn {\n            padding: 10px 18px;\n            font-size: 0.9rem;\n            font-weight: 600;\n            border: none;\n            border-radius: 25px;\n            background: rgba(255, 255, 255, 0.03);\n            color: #94a3b8;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            border: 1px solid rgba(255, 255, 255, 0.08);\n        }\n\n        .type-btn.active {\n            background: linear-gradient(135deg, #38bdf8, #6366f1);\n            color: #fff;\n            box-shadow: 0 0 15px rgba(56, 189, 248, 0.3);\n            border-color: transparent;\n        }\n\n        \/* Search Box *\/\n        .search-container {\n            max-width: 500px;\n            margin: 0 auto 25px;\n            position: relative;\n        }\n\n        .search-container input {\n            width: 100%;\n            padding: 14px 20px 14px 50px;\n            border: none;\n            border-radius: 25px;\n            background: rgba(15, 23, 42, 0.9);\n            color: #fff;\n            font-size: 1rem;\n            border: 1px solid rgba(56, 189, 248, 0.2);\n        }\n\n        .search-container input:focus {\n            outline: none;\n            border-color: #38bdf8;\n            box-shadow: 0 0 15px rgba(56, 189, 248, 0.3);\n        }\n\n        .search-container i {\n            position: absolute;\n            left: 20px;\n            top: 50%;\n            transform: translateY(-50%);\n            color: #38bdf8;\n        }\n\n        \/* Responsive Grid *\/\n        .gallery-container {\n            display: grid;\n            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));\n            gap: 15px;\n            max-width: 1300px;\n            margin: 0 auto;\n            padding: 5px;\n        }\n\n        @media (max-width: 480px) {\n            .gallery-container {\n                grid-template-columns: repeat(2, 1fr);\n                gap: 10px;\n            }\n        }\n\n        .gallery-item {\n            position: relative;\n            border-radius: 14px;\n            overflow: hidden;\n            cursor: pointer;\n            aspect-ratio: 1 \/ 1;\n            background: #111726;\n            border: 1px solid rgba(255, 255, 255, 0.05);\n            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease;\n        }\n\n        .gallery-item:hover {\n            transform: translateY(-5px) scale(1.02);\n            box-shadow: 0 10px 20px rgba(56, 189, 248, 0.25);\n        }\n\n        .gallery-item img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            display: block;\n        }\n\n        \/* Video Icon Overlay *\/\n        .play-overlay {\n            position: absolute;\n            inset: 0;\n            background: rgba(0, 0, 0, 0.4);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .play-icon {\n            width: 50px;\n            height: 50px;\n            background: rgba(255, 255, 255, 0.2);\n            backdrop-filter: blur(5px);\n            border-radius: 50%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            border: 2px solid #fff;\n        }\n\n        .play-icon i {\n            color: #fff;\n            font-size: 1.2rem;\n            margin-left: 3px;\n        }\n\n        \/* Full Screen Lightbox Modal *\/\n        .modal {\n            position: fixed;\n            inset: 0;\n            background: rgba(3, 5, 10, 0.98);\n            backdrop-filter: blur(15px);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            flex-direction: column;\n            opacity: 0;\n            pointer-events: none;\n            z-index: 9999;\n            transition: opacity 0.3s ease;\n            padding: 15px;\n        }\n\n        .modal.active {\n            opacity: 1;\n            pointer-events: auto;\n        }\n\n        .modal-body {\n            max-width: 95vw;\n            max-height: 70vh;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .modal img, .modal video {\n            max-width: 100%;\n            max-height: 70vh;\n            object-fit: contain;\n            border-radius: 12px;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.7);\n        }\n\n        .close-btn {\n            position: absolute;\n            top: 20px;\n            right: 25px;\n            font-size: 2.2rem;\n            color: #cbd5e1;\n            cursor: pointer;\n            transition: color 0.2s;\n        }\n\n        .close-btn:hover { color: #ef4444; }\n\n        .download-btn {\n            margin-top: 20px;\n            padding: 12px 35px;\n            font-size: 1rem;\n            font-weight: 600;\n            color: #fff;\n            background: linear-gradient(135deg, #10b981, #059669);\n            border: none;\n            border-radius: 25px;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            gap: 8px;\n            box-shadow: 0 8px 20px rgba(16, 185, 129, 0.3);\n        }\n    <\/style>\n<\/head>\n<body>\n\n    <div class=\"stats-dashboard\">\n        <div class=\"stat-item\">\n            <p><i class=\"fa-solid fa-database\"><\/i> মোট ফাইল কালেকশন<\/p>\n            <span id=\"totalMedia\">0<\/span>\n        <\/div>\n        <div class=\"stat-item\">\n            <p><i class=\"fa-solid fa-clock\"><\/i> আজকে নতুন আনলক<\/p>\n            <span id=\"dailyNew\" class=\"highlight\">0<\/span>\n        <\/div>\n        <div class=\"stat-item\">\n            <p><i class=\"fa-solid fa-layer-group\"><\/i> স্ক্রিনে দেখা যাচ্ছে<\/p>\n            <span id=\"currentView\" class=\"current-view\">0<\/span>\n        <\/div>\n    <\/div>\n\n    <header>\n        <h1>আল্ট্রা মিডিয়া ও প্রোফাইল গ্যালারি<\/h1>\n    <\/header>\n\n    <div class=\"media-type-switcher\">\n        <button class=\"type-btn active\" onclick=\"changeTab('photo')\"><i class=\"fa-solid fa-image\"><\/i> ফটো গ্যালারি<\/button>\n        <button class=\"type-btn\" onclick=\"changeTab('profile')\"><i class=\"fa-solid fa-user-circle\"><\/i> প্রোফাইল পিকচার<\/button>\n        <button class=\"type-btn\" onclick=\"changeTab('video')\"><i class=\"fa-solid fa-circle-play\"><\/i> ভিডিও কালেকশন<\/button>\n    <\/div>\n\n    <div class=\"search-container\">\n        <i class=\"fa-solid fa-magnifying-glass\"><\/i>\n        <input type=\"text\" id=\"searchInput\" placeholder=\"খুঁজুন (যেমন: গাড়ি, car, প্রকৃতি, gaming, ছেলে, মেয়ে)...\">\n    <\/div>\n\n    <main class=\"gallery-container\" id=\"galleryGrid\"><\/main>\n\n    <div class=\"modal\" id=\"mediaModal\">\n        <span class=\"close-btn\" onclick=\"closeModal()\"><i class=\"fa-solid fa-xmark\"><\/i><\/span>\n        <div class=\"modal-body\" id=\"modalContent\"><\/div>\n        <button class=\"download-btn\" id=\"downloadBtn\"><i class=\"fa-solid fa-download\"><\/i> গ্যালারিতে সেভ করুন<\/button>\n    <\/div>\n\n    <script>\n        let currentTab = 'photo';\n        let fullDatabase = [];\n        let currentlyUnlockedData = [];\n\n        \/\/ ১. প্রফেশনাল ও হাই-কোয়ালিটি সিডিএন ইমেজ ডেটাবেস (যা কখনো ভাঙবে না)\n        function generateSmartDatabase() {\n            let id = 1;\n\n            const configurations = [\n                { \n                    type: 'photo', \n                    tags: ['গাড়ি', 'car', 'supercar', 'গাড়ি', 'sports car'], \n                    ids: ['1503376780353-7e6692767b70', '1580273916550-e323be2ae537', '1552519507-da3b142c6e3d', '1492144534655-ae79c964c9d7', '1542282088-fe8426682b8f', '1525609004556-c46c7d6cf0a3', '1502877338535-766e1452684a', '1494976388531-d1058494cdd8', '1617788138017-80ad40651399', '1618843479313-40f8afb4b4d6'] \n                },\n                { \n                    type: 'photo', \n                    tags: ['প্রকৃতি', 'nature', 'landscape', 'nature pic', 'বন', 'পাহাড়'], \n                    ids: ['1470071459604-3b5ec3a7fe05', '1441974231531-c6227db76b6e', '1447752875215-b2761acb3c5d', '1472214222541-d510753a4907', '1501854140801-50d01698950b', '1469474968028-56623f02e42e', '1506744038136-46273834b3fb', '1446329813274-7c9036bd9a1f', '1513836279014-a89f7a76ae86', '1475924156734-496f6cac6ec1'] \n                },\n                { \n                    type: 'photo', \n                    tags: ['শহর', 'city', 'urban', 'city night', 'cyberpunk', 'building'], \n                    ids: ['1477959858617-67f85cf4f1df', '1519501025264-65ba15a82390', '1496568818309-53d7c7753022', '1514565131-fce0801e5785', '1444725494674-44270471151c', '1486406146926-c627a92ad1ab', '1470058869855-412f56c392b5', '1505705694340-019e1e335916'] \n                },\n                \/\/ প্রফেশনাল ও প্রিমিয়াম প্রোফাইল পিকচার কালেকশন (ছেলে, মেয়ে ও গেমিং)\n                { \n                    type: 'profile', \n                    tags: ['গেমিং', 'gaming', 'profile', 'gaming pic', 'avatar', 'গেমিং প্রোফাইল', 'cyberpunk'], \n                    ids: ['1538481199705-c710c4e965fc', '1542751371-adc38448a05e', '1511512578047-dfb367046420', '1560253023-3ec5d502959f', '1550745165-9bc0b252726f', '1552820728-8b83bb6b773f', '1612287230202-1bf1d85d1bdf', '1607604276583-eef5d076aa5f', '1560253023-3ec5d502959f', '1511512578047-dfb367046420'] \n                },\n                { \n                    type: 'profile', \n                    tags: ['ছেলে', 'boy', 'boys profile', 'man', 'ছেলেদের প্রোফাইল', 'handsome', 'স্মার্ট ছেলে'], \n                    ids: ['1500648767791-00dcc994a43e', '1539571696357-5a69c17a67c6', '1506794778202-cad84cf45f1d', '1618018352910-c5bda2c37f13', '1519085360753-af0119f7cbe7', '1480420936922-1b9d189b2c47', '1507003211169-0a1dd7228f2d', '1628157582853-a796fa650a6a', '1492562080023-ab3db95bfbce', '1522075469751-3a6694fb2f61', '1503443207922-dff3d65894b1', '1501196354995-cbb51c65aaea'] \n                },\n                { \n                    type: 'profile', \n                    tags: ['মেয়ে', 'girl', 'girls profile', 'woman', 'মেয়েদের প্রোফাইল', 'cute girl', 'সুন্দর মেয়ে'], \n                    ids: ['1494790108377-be9c29b29330', '1524504388940-b1c1722653e1', '1534528741775-53994a69daeb', '1517841905240-472988babdf9', '1488426862026-3ee34a7d66df', '1544005313-94ddf0286df2', '1554151228-14d9d10ee43c', '1529626455599-319b35c481d3', '1508214751196-bcfd4ca60f91', '1531746020798-e6953c6e8e04', '1521572267360-ee0c2909d518', '1519699047748-de8e457a634e'] \n                }\n            ];\n\n            \/\/ লুপ চালিয়ে ডাটাবেস বড় করার পাশাপাশি ছবি ইউনিক রাখা\n            configurations.forEach(config => {\n                \/\/ ১ থেকে ৫ বার ডুপ্লিকেট করে ভিন্ন এঙ্গেলে ক্রপ তৈরি যাতে কালেকশন বড় দেখায়\n                for (let loop = 0; loop < 4; loop++) { \n                    config.ids.forEach((imgId, index) => {\n                        let mediaUrl = `https:\/\/images.unsplash.com\/photo-${imgId}?auto=format&fit=crop&w=500&h=500&q=80&sig=${id}`;\n                        fullDatabase.push({\n                            id: id++,\n                            type: config.type,\n                            searchTags: config.tags,\n                            url: mediaUrl\n                        });\n                    });\n                }\n            });\n\n            \/\/ ২. ডাইনামিক অনলাইন ভিডিও কালেকশন\n            const premiumVideos = [\n                { id: 5001, type: 'video', searchTags: ['গাড়ি', 'car', 'car video'], thumb: 'https:\/\/images.unsplash.com\/photo-1503376780353-7e6692767b70?w=400', url: 'https:\/\/media.w3.org\/2010\/05\/bunny\/movie.mp4' },\n                { id: 5002, type: 'video', searchTags: ['প্রকৃতি', 'nature', 'nature video'], thumb: 'https:\/\/images.unsplash.com\/photo-1447752875215-b2761acb3c5d?w=400', url: 'https:\/\/vjs.zencdn.net\/v\/oceans.mp4' },\n                { id: 5003, type: 'video', searchTags: ['শহর', 'city', 'city video'], thumb: 'https:\/\/images.unsplash.com\/photo-1477959858617-67f85cf4f1df?w=400', url: 'https:\/\/media.w3.org\/2010\/05\/sintel\/trailer_hd.mp4' },\n                { id: 5004, type: 'video', searchTags: ['গেমিং', 'gaming', 'gaming video'], thumb: 'https:\/\/images.unsplash.com\/photo-1538481199705-c710c4e965fc?w=400', url: 'https:\/\/www.w3schools.com\/html\/mov_bbb.mp4' }\n            ];\n            fullDatabase = [...fullDatabase, ...premiumVideos];\n        }\n\n        \/\/ ৩. টাইম-লকড রিলিজ অ্যালগরিদম\n        function processHourlyUnlock() {\n            const currentHour = new Date().getHours(); \n            let totalUnlockedToday = 0;\n            currentlyUnlockedData = [];\n\n            for (let hour = 0; hour <= 24; hour++) {\n                let hourlyCount = Math.floor((Math.sin(hour + 3) + 1) * 3.5) + 2; \n                if (hour <= currentHour) {\n                    totalUnlockedToday += hourlyCount;\n                }\n            }\n\n            \/\/ প্রথম ৮০টি ছবি সর্বদা আনলক থাকবে, বাকিগুলো ঘণ্টা অনুযায়ী লাইভ হবে\n            let finalSelectionCount = Math.min(80 + totalUnlockedToday, fullDatabase.length);\n            currentlyUnlockedData = fullDatabase.slice(0, finalSelectionCount);\n            \n            document.getElementById('totalMedia').innerText = fullDatabase.length + \" টি\";\n            document.getElementById('dailyNew').innerText = \"+\" + totalUnlockedToday + \" আজ\";\n        }\n\n        \/\/ ৪. আল্ট্রা-স্মার্ট সার্চ অ্যান্ড ফিল্টার ইঞ্জিন\n        function renderGrid(searchFilter = '') {\n            const grid = document.getElementById('galleryGrid');\n            grid.innerHTML = '';\n            \n            const query = searchFilter.trim().toLowerCase();\n\n            const finalFiltered = currentlyUnlockedData.filter(item => {\n                const isCorrectTab = item.type === currentTab;\n                const isCorrectSearch = query === '' || item.searchTags.some(tag => tag.toLowerCase().includes(query));\n                return isCorrectTab && isCorrectSearch;\n            });\n\n            if(finalFiltered.length === 0) {\n                grid.innerHTML = `<p style=\"grid-column: 1\/-1; text-align:center; color:#64748b; padding:40px;\">সঠিক কি-ওয়ার্ড লিখুন (যেমন: car, গাড়ি, boy, girl, gaming, ছেলে, মেয়ে)<\/p>`;\n                document.getElementById('currentView').innerText = \"0 টি\";\n                return;\n            }\n\n            finalFiltered.forEach(item => {\n                const card = document.createElement('div');\n                card.className = 'gallery-item';\n\n                if (item.type === 'video') {\n                    card.innerHTML = `\n                        <img src=\"${item.thumb}\" alt=\"Video Thumbnail\" loading=\"lazy\">\n                        <div class=\"play-overlay\"><div class=\"play-icon\"><i class=\"fa-solid fa-play\"><\/i><\/div><\/div>\n                    `;\n                    card.onclick = () => openVideo(item.url);\n                } else {\n                    card.innerHTML = `<img src=\"${item.url}\" alt=\"Media\" loading=\"lazy\">`;\n                    card.onclick = () => openPhoto(item.url);\n                }\n                grid.appendChild(card);\n            });\n\n            document.getElementById('currentView').innerText = finalFiltered.length + \" টি\";\n        }\n\n        \/\/ ৫. ট্যাব পরিবর্তন হ্যান্ডলার (বাগ ফ্রি মেথড)\n        function changeTab(tabName) {\n            currentTab = tabName;\n            \n            \/\/ একটিভ ক্লাস ঠিক করা\n            document.querySelectorAll('.type-btn').forEach(btn => {\n                if(btn.getAttribute('onclick').includes(tabName)) {\n                    btn.classList.add('active');\n                } else {\n                    btn.classList.remove('active');\n                }\n            });\n\n            document.getElementById('searchInput').value = ''; \/\/ সার্চবার রিসেট\n            renderGrid();\n        }\n\n        \/\/ লাইভ সার্চ লিসেনার\n        document.getElementById('searchInput').addEventListener('input', (e) => {\n            renderGrid(e.target.value);\n        });\n\n        \/\/ ৬. ফুল স্ক্রিন মোডাল ও প্লেব্যাক সিস্টেম\n        function openPhoto(url) {\n            document.getElementById('modalContent').innerHTML = `<img id=\"activeMedia\" src=\"${url}\">`;\n            document.getElementById('mediaModal').classList.add('active');\n            document.getElementById('downloadBtn').onclick = () => downloadMedia(url, 'image.jpg');\n        }\n\n        function openVideo(url) {\n            document.getElementById('modalContent').innerHTML = `\n                <video id=\"activeMedia\" controls autoplay loop style=\"width:100%; max-height: 70vh;\">\n                    <source src=\"${url}\" type=\"video\/mp4\">\n                <\/video>`;\n            document.getElementById('mediaModal').classList.add('active');\n            document.getElementById('downloadBtn').onclick = () => downloadMedia(url, 'video.mp4');\n        }\n\n        function closeModal() {\n            const media = document.getElementById('activeMedia');\n            if (media && media.tagName === 'VIDEO') media.pause(); \n            document.getElementById('mediaModal').classList.remove('active');\n        }\n\n        \/\/ ৭. প্রফেশনাল ফাইল ডাউনলোডার (CORS সাপোর্টেড)\n        async function downloadMedia(url, filename) {\n            const btn = document.getElementById('downloadBtn');\n            try {\n                btn.innerHTML = `<i class=\"fa-solid fa-spinner fa-spin\"><\/i> সেভ হচ্ছে...`;\n                const res = await fetch(url);\n                const blob = await res.blob();\n                const blobUrl = URL.createObjectURL(blob);\n                \n                const a = document.createElement('a');\n                a.href = blobUrl;\n                a.download = `SmartGallery_${Date.now()}_${filename}`;\n                document.body.appendChild(a);\n                a.click();\n                document.body.removeChild(a);\n                \n                btn.innerHTML = `<i class=\"fa-solid fa-circle-check\"><\/i> সেভ কমপ্লিট!`;\n                setTimeout(() => btn.innerHTML = `<i class=\"fa-solid fa-download\"><\/i> গ্যালারিতে সেভ করুন`, 2000);\n            } catch {\n                alert(\"ডাউনলোড সম্পন্ন করা যায়নি, আবার চেষ্টা করুন।\");\n                btn.innerHTML = `<i class=\"fa-solid fa-download\"><\/i> গ্যালারিতে সেভ করুন`;\n            }\n        }\n\n        \/\/ অ্যাপ ইনিশিয়েশন\n        generateSmartDatabase();\n        processHourlyUnlock();\n        renderGrid();\n        \n        \/\/ টাইম ট্র্যাকিং ইন্টারভাল\n        setInterval(processHourlyUnlock, 60000);\n    <\/script>\n<\/body>\n<\/html>\n","icon":"\/9j\/4AAQSkZJRgABAQAAAQABAAD\\/bAEMADQkKCwoIDQsKCw4ODQ8TIBUTEhITJxweFyAuKTEwLiktLDM6Sj4zNkY3LC1AV0FGTE5SU1IyPlphWlBgSlFST\/\/bAEMBDg4OExETJhUVJk81LTVPT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT09PT\/\/AABEIAGAAYAMBIgACEQEDEQH\/xAAbAAACAwEBAQAAAAAAAAAAAAAFBgIDBAEHAP\/EAEEQAAEDAgIDCwkGBgMAAAAAAAEAAgMEEQUhEjFBBgcTFlFhcYOjwuEiM1JUZIGRscEUIzJigqFCU2Ny8PGistH\/xAAZAQACAwEAAAAAAAAAAAAAAAACBAABBQP\/xAAqEQABBAECBAUFAQAAAAAAAAABAAIDBBESISIjMUEUUYGhsRMyQnHRYf\/aAAwDAQACEQMRAD8A86VkEEtRJwcEZe7m2L6ngfU1DIIh5TzYcycqSkipYWxRNsBrO0nlKEnC16lUznJOAEAi3Pzu87KxnRdxVvFw+tdn4piDFY2K+xBrWr4Gu0bj3KWuLZ9b7PxXeLR9b7PxTS2C+xWCm5lWtC